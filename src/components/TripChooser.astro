---
import { site } from "@data/site";
import { imagePath, withBase } from "@lib/links";
import { CalendarDays, CheckCircle2 } from "@lucide/astro";

const groupForTrip = new Map(
  site.tripGroups.flatMap((group) => group.tripSlugs.map((slug) => [slug, group.title]))
);
const initialGroup = site.tripGroups[0]?.title ?? "";
const initialTripSlug = site.tripGroups[0]?.tripSlugs[0] ?? site.tripTypes[0]?.slug ?? "";
---

<section class="trip-chooser rounded-lg border border-sky-100 bg-white/92 p-3 shadow-[0_24px_70px_rgba(16,80,103,0.12)] md:p-5" data-trip-chooser>
  <div class="grid gap-5 lg:grid-cols-[16rem_1fr]">
    <aside class="rounded-lg border border-sky-100 bg-sky-50/70 p-3">
      <div class="grid gap-2" role="tablist" aria-label="Trip categories">
        {
          site.tripGroups.map((group) => (
            <button
              type="button"
              class:list={[
                "trip-filter rounded-lg border border-transparent px-4 py-3 text-left text-sm font-black text-ink transition hover:border-seafoam/45 hover:bg-white",
                group.title === initialGroup && "is-active"
              ]}
              data-trip-filter={group.title}
              aria-pressed={group.title === initialGroup ? "true" : "false"}
            >
              <span class="block">{group.title}</span>
              <span class="mt-1 block text-xs font-bold text-mist">{group.tripSlugs.length} options</span>
            </button>
          ))
        }
      </div>
    </aside>

    <div class="grid gap-5 xl:grid-cols-[minmax(0,1.35fr)_minmax(20rem,0.85fr)]">
      <div class="overflow-hidden rounded-lg border border-sky-100 bg-white">
        <div class="hidden grid-cols-[minmax(9rem,1fr)_5rem_5rem_8rem] gap-3 border-b border-sky-100 bg-sky-50/80 px-4 py-3 text-xs font-black uppercase tracking-[0.14em] text-[#46717c] md:grid">
          <span>Trip</span>
          <span>Length</span>
          <span>Rate</span>
          <span>Time</span>
        </div>
        <div class="divide-y divide-sky-100">
          {
            site.tripTypes.map((trip) => {
              const groupTitle = groupForTrip.get(trip.slug) ?? initialGroup;
              const isInitial = trip.slug === initialTripSlug;

              return (
                <button
                  id={trip.slug}
                  type="button"
                  class:list={[
                    "trip-row grid w-full gap-3 px-3 py-4 text-left transition hover:bg-sky-50 md:grid-cols-[minmax(9rem,1fr)_5rem_5rem_8rem] md:items-center md:px-4",
                    isInitial && "is-active"
                  ]}
                  hidden={groupTitle !== initialGroup}
                  data-trip-row
                  data-trip-id={trip.slug}
                  data-trip-group={groupTitle}
                  aria-pressed={isInitial ? "true" : "false"}
                >
                  <span class="min-w-0">
                    <span class="eyebrow mb-1 block">{trip.eyebrow}</span>
                    <strong class="block text-base font-black text-ink">{trip.name}</strong>
                  </span>
                  <span class="grid grid-cols-2 gap-2 md:contents">
                    <span class="rounded-md bg-sky-50 p-2 text-sm font-extrabold text-ink md:bg-transparent md:p-0">
                      <span class="mb-1 block text-[0.68rem] font-black uppercase tracking-[0.12em] text-[#46717c] md:hidden">Length</span>
                      {trip.duration}
                    </span>
                    <span class="rounded-md bg-sky-50 p-2 text-sm font-extrabold text-ink md:bg-transparent md:p-0">
                      <span class="mb-1 block text-[0.68rem] font-black uppercase tracking-[0.12em] text-[#46717c] md:hidden">Rate</span>
                      {trip.price}
                    </span>
                    <span class="col-span-2 rounded-md bg-sky-50 p-2 text-sm font-bold leading-5 text-mist md:col-auto md:bg-transparent md:p-0">
                      <span class="mb-1 block text-[0.68rem] font-black uppercase tracking-[0.12em] text-[#46717c] md:hidden">Time</span>
                      {trip.times}
                    </span>
                  </span>
                </button>
              );
            })
          }
        </div>
      </div>

      <aside class="rounded-lg border border-sky-100 bg-white p-4 shadow-[0_18px_44px_rgba(16,80,103,0.10)]">
        {
          site.tripTypes.map((trip) => (
            <article class="trip-panel" data-trip-panel={trip.slug} hidden={trip.slug !== initialTripSlug}>
              <img
                src={imagePath(trip.image)}
                alt={`${trip.name} Ocean City charter trip`}
                class="aspect-[16/10] w-full rounded-lg bg-white object-cover"
                loading="lazy"
                decoding="async"
              />
              <div class="mt-5">
                <p class="eyebrow mb-2">{trip.eyebrow}</p>
                <h3 class="text-2xl font-black leading-tight text-ink">{trip.name}</h3>
                <p class="mt-3 text-sm leading-7 text-mist">{trip.description}</p>
              </div>

              <div class="mt-5 grid gap-2 text-center text-sm sm:grid-cols-3">
                <div class="rounded-lg bg-sky-50 p-3">
                  <p class="text-xs font-black uppercase tracking-[0.12em] text-[#46717c]">Length</p>
                  <p class="mt-1 font-black text-ink">{trip.duration}</p>
                </div>
                <div class="rounded-lg bg-sky-50 p-3">
                  <p class="text-xs font-black uppercase tracking-[0.12em] text-[#46717c]">Rate</p>
                  <p class="mt-1 font-black text-ink">{trip.price}</p>
                </div>
                <div class="rounded-lg bg-sky-50 p-3">
                  <p class="text-xs font-black uppercase tracking-[0.12em] text-[#46717c]">Guests</p>
                  <p class="mt-1 font-black text-ink">Up to 6</p>
                </div>
              </div>

              <div class="mt-5">
                <h4 class="text-xs font-black uppercase tracking-[0.14em] text-ink">Best for</h4>
                <p class="mt-2 text-sm leading-7 text-mist">{trip.bestFor}</p>
              </div>

              <div class="mt-5">
                <h4 class="text-xs font-black uppercase tracking-[0.14em] text-ink">Targets</h4>
                <div class="mt-3 flex flex-wrap gap-2">
                  {trip.targetSpecies.map((species) => (
                    <a
                      href={withBase("/trips/#common-catches")}
                      class="rounded-lg border border-seafoam/25 bg-seafoam/10 px-3 py-1 text-xs font-bold text-ink transition hover:border-seafoam/50"
                    >
                      {species}
                    </a>
                  ))}
                </div>
              </div>

              <ul class="mt-5 grid gap-2 text-sm text-mist">
                {trip.included.map((item) => (
                  <li class="flex gap-2">
                    <CheckCircle2 class="mt-0.5 size-4 shrink-0 text-seafoam" aria-hidden="true" />
                    <span>{item}</span>
                  </li>
                ))}
              </ul>

              <a
                href={withBase(`/book/?trip=${trip.slug}`)}
                class="mt-5 inline-flex min-h-12 w-full items-center justify-center gap-2 rounded-lg border border-seafoam bg-seafoam px-5 py-3 text-sm font-extrabold text-ink transition hover:bg-aqua"
              >
                <CalendarDays class="size-4" aria-hidden="true" />
                <span>Book This Trip</span>
              </a>
            </article>
          ))
        }
      </aside>
    </div>
  </div>
</section>

<style>
  .trip-filter.is-active,
  .trip-row.is-active {
    border-color: rgba(53, 224, 202, 0.55);
    background: #ffffff;
    box-shadow: 0 12px 28px rgba(16, 80, 103, 0.10);
  }

  .trip-panel[hidden] {
    display: none;
  }

  .trip-row[hidden] {
    display: none;
  }

  .trip-row {
    scroll-margin-top: 7rem;
  }
</style>

<script>
  (() => {
    const root = document.querySelector("[data-trip-chooser]");
    if (!root) return;

    const filters = Array.from(root.querySelectorAll("[data-trip-filter]"));
    const rows = Array.from(root.querySelectorAll("[data-trip-row]"));
    const panels = Array.from(root.querySelectorAll("[data-trip-panel]"));

    const setGroup = (group, selectFirst = true) => {
      filters.forEach((filter) => {
        const active = filter.dataset.tripFilter === group;
        filter.classList.toggle("is-active", active);
        filter.setAttribute("aria-pressed", String(active));
      });

      rows.forEach((row) => {
        row.hidden = row.dataset.tripGroup !== group;
      });

      if (selectFirst) {
        const firstRow = rows.find((row) => !row.hidden);
        if (firstRow) setTrip(firstRow.dataset.tripId);
      }
    };

    const setTrip = (tripId, updateHash = false, shouldScroll = false) => {
      const selectedRow = rows.find((row) => row.dataset.tripId === tripId);
      if (!selectedRow) return false;

      setGroup(selectedRow.dataset.tripGroup, false);

      rows.forEach((row) => {
        const active = row.dataset.tripId === tripId;
        row.classList.toggle("is-active", active);
        row.setAttribute("aria-pressed", String(active));
      });

      panels.forEach((panel) => {
        panel.hidden = panel.dataset.tripPanel !== tripId;
      });

      if (updateHash) {
        history.replaceState(null, "", `#${tripId}`);
      }

      if (shouldScroll) {
        window.setTimeout(() => {
          selectedRow.scrollIntoView({ block: "center" });
        }, 80);
      }

      return true;
    };

    filters.forEach((filter) => {
      filter.addEventListener("click", () => setGroup(filter.dataset.tripFilter));
    });

    rows.forEach((row) => {
      row.addEventListener("click", () => setTrip(row.dataset.tripId, true));
    });

    const activateHash = () => {
      const tripId = decodeURIComponent(window.location.hash.replace("#", ""));
      if (!tripId) return false;
      return setTrip(tripId, false, true);
    };

    if (!activateHash()) {
      const activeFilter = filters.find((filter) => filter.classList.contains("is-active"));
      if (activeFilter) setGroup(activeFilter.dataset.tripFilter, false);
    }

    window.addEventListener("hashchange", activateHash);
  })();
</script>
