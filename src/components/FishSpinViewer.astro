---
import { ChevronLeft, ChevronRight, RotateCcw, ZoomIn, ZoomOut } from "@lucide/astro";
import { imagePath } from "@lib/links";

interface Props {
  title?: string;
  frames: readonly string[];
  alt?: string;
  autoplay?: boolean;
  autoplaySpeed?: number;
}

const {
  title = "Black sea bass",
  frames,
  alt = `${title} 360 spin viewer`,
  autoplay = true,
  autoplaySpeed = 1350
} = Astro.props;

const resolvedFrames = frames.map((frame) => imagePath(frame));
const firstFrame = resolvedFrames[0] ?? "";
const viewerId = `fish-spin-${title.toLowerCase().replace(/[^a-z0-9]+/g, "-")}-${Math.random()
  .toString(36)
  .slice(2, 8)}`;
---

<div
  id={viewerId}
  class="fish-spin-viewer"
  tabindex="0"
  data-fish-spin
  aria-label={alt}
>
  <button type="button" class="fish-spin-step left" aria-label={`Rotate ${title} left`} data-spin-prev>
    <ChevronLeft class="size-5" aria-hidden="true" />
  </button>

  <div class="fish-spin-stage">
    <img src={firstFrame} alt={alt} draggable="false" loading="lazy" decoding="async" data-spin-image />
  </div>

  <button type="button" class="fish-spin-step right" aria-label={`Rotate ${title} right`} data-spin-next>
    <ChevronRight class="size-5" aria-hidden="true" />
  </button>

  <div class="fish-spin-controls" aria-label={`${title} viewer controls`}>
    <button type="button" aria-label={`Zoom into ${title}`} data-spin-zoom-in>
      <ZoomIn class="size-4" aria-hidden="true" />
    </button>
    <button type="button" aria-label={`Zoom out from ${title}`} data-spin-zoom-out>
      <ZoomOut class="size-4" aria-hidden="true" />
    </button>
    <button type="button" aria-label={`Reset ${title} view`} data-spin-reset>
      <RotateCcw class="size-4" aria-hidden="true" />
    </button>
  </div>

  <div class="fish-spin-dots" aria-hidden="true">
    {resolvedFrames.map((_frame, index) => <span class={index === 0 ? "active" : ""}></span>)}
  </div>
</div>

<script define:vars={{ viewerId, frames: resolvedFrames, autoplay, autoplaySpeed }}>
  const root = document.getElementById(viewerId);

  if (root instanceof HTMLElement && Array.isArray(frames) && frames.length > 0) {
    const image = root.querySelector("[data-spin-image]");
    const previousButton = root.querySelector("[data-spin-prev]");
    const nextButton = root.querySelector("[data-spin-next]");
    const zoomInButton = root.querySelector("[data-spin-zoom-in]");
    const zoomOutButton = root.querySelector("[data-spin-zoom-out]");
    const resetButton = root.querySelector("[data-spin-reset]");
    const dots = Array.from(root.querySelectorAll(".fish-spin-dots span"));

    if (image instanceof HTMLImageElement) {
      frames.forEach((src) => {
        const preload = new Image();
        preload.src = src;
      });

      let frameIndex = 0;
      let zoom = 1;
      let dragStartX = 0;
      let dragging = false;
      let autoplayTimer = 0;

      const clampZoom = (value) => Math.min(2.4, Math.max(1, value));

      const render = () => {
        image.src = frames[frameIndex];
        image.style.setProperty("--fish-zoom", String(zoom));
        root.dataset.frame = String(frameIndex + 1);
        root.dataset.zoom = zoom.toFixed(2);
        dots.forEach((dot, index) => dot.classList.toggle("active", index === frameIndex));
      };

      const rotate = (direction) => {
        frameIndex = (frameIndex + direction + frames.length) % frames.length;
        render();
      };

      const setZoom = (value) => {
        zoom = clampZoom(value);
        render();
      };

      const stopAutoplay = () => {
        window.clearInterval(autoplayTimer);
        autoplayTimer = 0;
      };

      const startAutoplay = () => {
        if (!autoplay || window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        stopAutoplay();
        autoplayTimer = window.setInterval(() => rotate(1), autoplaySpeed);
      };

      previousButton?.addEventListener("click", () => {
        stopAutoplay();
        rotate(-1);
      });

      nextButton?.addEventListener("click", () => {
        stopAutoplay();
        rotate(1);
      });

      zoomInButton?.addEventListener("click", () => {
        stopAutoplay();
        setZoom(zoom + 0.2);
      });

      zoomOutButton?.addEventListener("click", () => {
        stopAutoplay();
        setZoom(zoom - 0.2);
      });

      resetButton?.addEventListener("click", () => {
        stopAutoplay();
        frameIndex = 0;
        zoom = 1;
        render();
      });

      root.addEventListener("pointerdown", (event) => {
        const target = event.target;
        if (target instanceof Element && target.closest("button")) return;
        dragging = true;
        dragStartX = event.clientX;
        root.setPointerCapture(event.pointerId);
        root.classList.add("is-dragging");
        stopAutoplay();
      });

      root.addEventListener("pointermove", (event) => {
        if (!dragging) return;
        const delta = event.clientX - dragStartX;
        if (Math.abs(delta) < 22) return;
        rotate(delta > 0 ? -1 : 1);
        dragStartX = event.clientX;
      });

      const endDrag = (event) => {
        if (!dragging) return;
        dragging = false;
        root.classList.remove("is-dragging");
        if (root.hasPointerCapture(event.pointerId)) {
          root.releasePointerCapture(event.pointerId);
        }
      };

      root.addEventListener("pointerup", endDrag);
      root.addEventListener("pointercancel", endDrag);
      root.addEventListener("mouseenter", stopAutoplay);
      root.addEventListener("mouseleave", () => {
        if (!dragging) startAutoplay();
      });

      root.addEventListener(
        "wheel",
        (event) => {
          event.preventDefault();
          stopAutoplay();
          setZoom(zoom + (event.deltaY < 0 ? 0.12 : -0.12));
        },
        { passive: false }
      );

      root.addEventListener("keydown", (event) => {
        if (event.key === "ArrowLeft") {
          event.preventDefault();
          stopAutoplay();
          rotate(-1);
        }
        if (event.key === "ArrowRight") {
          event.preventDefault();
          stopAutoplay();
          rotate(1);
        }
        if (event.key === "+" || event.key === "=") {
          event.preventDefault();
          stopAutoplay();
          setZoom(zoom + 0.2);
        }
        if (event.key === "-") {
          event.preventDefault();
          stopAutoplay();
          setZoom(zoom - 0.2);
        }
        if (event.key === "0") {
          event.preventDefault();
          stopAutoplay();
          frameIndex = 0;
          zoom = 1;
          render();
        }
      });

      render();
      startAutoplay();

      window.addEventListener("pagehide", stopAutoplay);
    }
  }
</script>

<style>
  .fish-spin-viewer {
    position: relative;
    isolation: isolate;
    aspect-ratio: 4 / 3;
    min-height: 220px;
    overflow: hidden;
    background:
      radial-gradient(circle at 50% 18%, rgba(255, 255, 255, 0.96), rgba(225, 246, 250, 0.9) 44%, rgba(158, 225, 235, 0.7) 100%),
      linear-gradient(180deg, #ffffff, #daf4f8);
    cursor: grab;
    user-select: none;
    touch-action: pan-y;
  }

  .fish-spin-viewer::before {
    position: absolute;
    inset: 11% 12% 15%;
    z-index: -1;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(53, 224, 202, 0.32), rgba(53, 224, 202, 0) 66%);
    content: "";
    filter: blur(12px);
  }

  .fish-spin-viewer:focus-visible {
    box-shadow: var(--focus-ring);
  }

  .fish-spin-viewer.is-dragging {
    cursor: grabbing;
  }

  .fish-spin-stage {
    display: grid;
    height: 100%;
    place-items: center;
    overflow: hidden;
    padding: 1.35rem 2.8rem 2.55rem;
  }

  .fish-spin-stage img {
    width: 100%;
    height: 100%;
    max-height: 100%;
    max-width: 100%;
    object-fit: contain;
    pointer-events: none;
    transform: scale(var(--fish-zoom, 1));
    transform-origin: center;
    transition: transform 160ms ease, filter 160ms ease;
    filter: drop-shadow(0 20px 28px rgba(8, 32, 43, 0.18));
    will-change: transform;
  }

  .fish-spin-step,
  .fish-spin-controls button {
    display: grid;
    place-items: center;
    border: 1px solid rgba(8, 32, 43, 0.12);
    border-radius: 0.5rem;
    background: rgba(255, 255, 255, 0.78);
    color: #08202b;
    box-shadow: 0 12px 30px rgba(16, 80, 103, 0.14);
    transition: transform 140ms ease, border-color 140ms ease, background 140ms ease;
  }

  .fish-spin-step:hover,
  .fish-spin-controls button:hover {
    border-color: rgba(7, 136, 165, 0.42);
    background: #ffffff;
    transform: translateY(-1px);
  }

  .fish-spin-step {
    position: absolute;
    top: 50%;
    z-index: 3;
    width: 2.35rem;
    height: 2.35rem;
    transform: translateY(-50%);
  }

  .fish-spin-step:hover {
    transform: translateY(calc(-50% - 1px));
  }

  .fish-spin-step.left {
    left: 0.72rem;
  }

  .fish-spin-step.right {
    right: 0.72rem;
  }

  .fish-spin-controls {
    position: absolute;
    right: 0.75rem;
    bottom: 0.75rem;
    z-index: 3;
    display: flex;
    gap: 0.35rem;
  }

  .fish-spin-controls button {
    width: 2.15rem;
    height: 2.15rem;
  }

  .fish-spin-dots {
    position: absolute;
    bottom: 1.15rem;
    left: 50%;
    z-index: 2;
    display: flex;
    gap: 0.35rem;
    transform: translateX(-50%);
  }

  .fish-spin-dots span {
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 999px;
    background: rgba(8, 32, 43, 0.22);
    transition: background 140ms ease, transform 140ms ease;
  }

  .fish-spin-dots span.active {
    background: #0788a5;
    transform: scale(1.25);
  }

  @media (max-width: 520px) {
    .fish-spin-stage {
      padding-inline: 2.35rem;
    }

    .fish-spin-step {
      width: 2rem;
      height: 2rem;
    }
  }
</style>
