---
import { ChevronLeft, ChevronRight } from "@lucide/astro";
import { imagePath } from "@lib/links";

interface Props {
  title?: string;
  frames: readonly string[];
  alt?: string;
  autoplay?: boolean;
  autoplaySpeed?: number;
}

const {
  title = "Black sea bass",
  frames,
  alt = `${title} 360 image viewer`,
  autoplay = false,
  autoplaySpeed = 1350
} = Astro.props;

const resolvedFrames = frames.map((frame) => imagePath(frame));
const firstFrame = resolvedFrames[0] ?? "";
---

<div
  class="fish-spin-viewer"
  tabindex="0"
  data-fish-spin
  data-fish-frames={JSON.stringify(resolvedFrames)}
  data-fish-autoplay={String(autoplay)}
  data-fish-speed={String(autoplaySpeed)}
  aria-label={alt}
>
  <button type="button" class="fish-spin-step left" aria-label={`Rotate ${title} left`} data-spin-prev>
    <ChevronLeft class="size-5" aria-hidden="true" />
  </button>

  <div class="fish-spin-stage">
    <img src={firstFrame} alt={alt} draggable="false" loading="lazy" decoding="async" data-spin-image />
  </div>

  <button type="button" class="fish-spin-step right" aria-label={`Rotate ${title} right`} data-spin-next>
    <ChevronRight class="size-5" aria-hidden="true" />
  </button>
</div>

<script>
  document.querySelectorAll("[data-fish-spin]").forEach((root) => {
    if (!(root instanceof HTMLElement) || root.dataset.fishInitialized === "true") return;

    const image = root.querySelector("[data-spin-image]");
    const previousButton = root.querySelector("[data-spin-prev]");
    const nextButton = root.querySelector("[data-spin-next]");
    const frames = parseFrames(root.dataset.fishFrames);

    if (!(image instanceof HTMLImageElement) || !frames.length) return;

    root.dataset.fishInitialized = "true";

    frames.forEach((src) => {
      const preload = new Image();
      preload.src = src;
    });

    const autoplay = root.dataset.fishAutoplay === "true";
    const autoplaySpeed = Number(root.dataset.fishSpeed) || 1350;
    let frameIndex = 0;
    let dragStartX = 0;
    let dragging = false;
    let autoplayTimer = 0;

    const render = () => {
      image.src = frames[frameIndex];
      root.dataset.frame = String(frameIndex + 1);
    };

    const rotate = (direction) => {
      frameIndex = (frameIndex + direction + frames.length) % frames.length;
      render();
    };

    const stopAutoplay = () => {
      window.clearInterval(autoplayTimer);
      autoplayTimer = 0;
    };

    const startAutoplay = () => {
      if (!autoplay || window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
      stopAutoplay();
      autoplayTimer = window.setInterval(() => rotate(1), autoplaySpeed);
    };

    previousButton?.addEventListener("click", () => {
      stopAutoplay();
      rotate(-1);
    });

    nextButton?.addEventListener("click", () => {
      stopAutoplay();
      rotate(1);
    });

    root.addEventListener("pointerdown", (event) => {
      const target = event.target;
      if (target instanceof Element && target.closest("button")) return;
      dragging = true;
      dragStartX = event.clientX;
      root.setPointerCapture(event.pointerId);
      root.classList.add("is-dragging");
      stopAutoplay();
    });

    root.addEventListener("pointermove", (event) => {
      if (!dragging) return;
      const delta = event.clientX - dragStartX;
      if (Math.abs(delta) < 20) return;
      rotate(delta > 0 ? -1 : 1);
      dragStartX = event.clientX;
    });

    const endDrag = (event) => {
      if (!dragging) return;
      dragging = false;
      root.classList.remove("is-dragging");
      if (root.hasPointerCapture(event.pointerId)) {
        root.releasePointerCapture(event.pointerId);
      }
    };

    root.addEventListener("pointerup", endDrag);
    root.addEventListener("pointercancel", endDrag);
    root.addEventListener("mouseenter", stopAutoplay);
    root.addEventListener("mouseleave", () => {
      if (!dragging) startAutoplay();
    });

    root.addEventListener("keydown", (event) => {
      if (event.key === "ArrowLeft") {
        event.preventDefault();
        stopAutoplay();
        rotate(-1);
      }
      if (event.key === "ArrowRight") {
        event.preventDefault();
        stopAutoplay();
        rotate(1);
      }
    });

    render();
    startAutoplay();

    window.addEventListener("pagehide", stopAutoplay, { once: true });
  });

  function parseFrames(value) {
    if (!value) return [];
    try {
      const parsed = JSON.parse(value);
      return Array.isArray(parsed) ? parsed.filter((item) => typeof item === "string") : [];
    } catch (_error) {
      return [];
    }
  }
</script>

<style>
  .fish-spin-viewer {
    position: relative;
    isolation: isolate;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.97), rgba(225, 247, 250, 0.94)),
      linear-gradient(135deg, rgba(53, 224, 202, 0.12), rgba(243, 184, 91, 0.08));
    cursor: grab;
    user-select: none;
    touch-action: pan-y;
  }

  .fish-spin-viewer:focus-visible {
    box-shadow: var(--focus-ring);
  }

  .fish-spin-viewer.is-dragging {
    cursor: grabbing;
  }

  .fish-spin-stage {
    display: grid;
    height: 100%;
    place-items: center;
    overflow: hidden;
    padding: 1.1rem 2.65rem 1.35rem;
  }

  .fish-spin-stage img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    pointer-events: none;
    filter: drop-shadow(0 20px 28px rgba(8, 32, 43, 0.18));
  }

  .fish-spin-step {
    position: absolute;
    top: 50%;
    z-index: 3;
    display: grid;
    width: 2.35rem;
    height: 2.35rem;
    place-items: center;
    border: 1px solid rgba(8, 32, 43, 0.12);
    border-radius: 0.5rem;
    background: rgba(255, 255, 255, 0.82);
    color: #08202b;
    box-shadow: 0 12px 30px rgba(16, 80, 103, 0.14);
    transform: translateY(-50%);
    transition: transform 140ms ease, border-color 140ms ease, background 140ms ease;
  }

  .fish-spin-step:hover {
    border-color: rgba(7, 136, 165, 0.42);
    background: #ffffff;
    transform: translateY(calc(-50% - 1px));
  }

  .fish-spin-step.left {
    left: 0.72rem;
  }

  .fish-spin-step.right {
    right: 0.72rem;
  }

  @media (max-width: 520px) {
    .fish-spin-stage {
      padding-inline: 2.2rem;
    }

    .fish-spin-step {
      width: 2rem;
      height: 2rem;
    }
  }
</style>
