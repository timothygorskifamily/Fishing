---
import { site } from "@data/site";
import { imagePath, phoneHref, withBase } from "@lib/links";
import { CalendarDays, Menu, Phone, X } from "@lucide/astro";

const currentPath = Astro.url.pathname.replace(import.meta.env.BASE_URL, "/");
const isActive = (href: string) => {
  if (href === "/") {
    return currentPath === "/";
  }
  return currentPath.startsWith(href);
};

const navMascots: Record<string, string> = {
  "/trips/": "trips-mascot.png",
  "/fishing-report/": "report-mascot.png",
  "/boat/": "boat-mascot.png",
  "/gallery/": "gallery-mascot.png",
  "/faq/": "thinking-fish-faq.png",
  "/contact/": "contact-mascot.png",
  "/book/": "book-mascot.png"
};
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-ink/95 backdrop-blur-xl">
  <div class="container-shell flex min-h-20 items-center justify-between gap-2 md:gap-4">
    <a href={withBase("/")} class="group flex items-center" aria-label={`${site.businessName} home`}>
      <span class="rounded-lg bg-white px-2 py-1 shadow-[0_10px_32px_rgba(0,0,0,0.24)] ring-1 ring-white/18 transition group-hover:ring-seafoam/55">
        <img
          src={imagePath(site.logoImage)}
          alt={site.businessName}
          class="h-14 w-auto max-w-[5.5rem] object-contain sm:h-16 sm:max-w-[6.25rem] md:h-[4.25rem] md:max-w-[6.75rem]"
          loading="eager"
          decoding="async"
        />
      </span>
    </a>

    <nav class="hidden items-center gap-1 md:flex" aria-label="Primary navigation">
      {
        site.navLinks.map((link) => {
          const mascot = navMascots[link.href];

          return (
            <span class="nav-preview-item relative inline-flex">
              <a
                href={withBase(link.href)}
                class:list={[
                  "rounded-lg px-3 py-2 text-sm font-bold text-mist transition hover:bg-white/6 hover:text-white",
                  isActive(link.href) && "bg-white/8 text-white"
                ]}
              >
                {link.label}
              </a>
              {mascot && (
                <img
                  src={imagePath(mascot)}
                  alt=""
                  class="nav-preview pointer-events-none absolute left-1/2 top-[calc(100%+0.75rem)] z-50 aspect-square w-44 max-w-none -translate-x-1/2 translate-y-2 rounded-2xl border border-white/30 bg-white object-cover p-1 opacity-0 shadow-[0_22px_70px_rgba(0,0,0,0.38)]"
                  loading="lazy"
                  decoding="async"
                  aria-hidden="true"
                />
              )}
            </span>
          );
        })
      }
    </nav>

    <div class="hidden items-center gap-2 md:flex">
      <a
        href={phoneHref(site.phone)}
        class="inline-flex min-h-11 items-center justify-center gap-2 rounded-lg border border-white/12 px-4 py-2 text-sm font-extrabold text-fog transition hover:border-seafoam/45 hover:text-white"
      >
        <Phone class="size-4" aria-hidden="true" />
        <span>{site.phone}</span>
      </a>
      <span class="nav-preview-item relative inline-flex">
        <a
          href={withBase("/book/")}
          class="inline-flex min-h-11 items-center justify-center gap-2 rounded-lg bg-gold px-4 py-2 text-sm font-extrabold text-ink transition hover:bg-[#ffd083]"
        >
          <CalendarDays class="size-4" aria-hidden="true" />
          <span>Book Now</span>
        </a>
        <img
          src={imagePath(navMascots["/book/"])}
          alt=""
          class="nav-preview pointer-events-none absolute left-1/2 top-[calc(100%+0.75rem)] z-50 aspect-square w-44 max-w-none -translate-x-1/2 translate-y-2 rounded-2xl border border-white/30 bg-white object-cover p-1 opacity-0 shadow-[0_22px_70px_rgba(0,0,0,0.38)]"
          loading="lazy"
          decoding="async"
          aria-hidden="true"
        />
      </span>
    </div>

    <details class="group relative md:hidden">
      <summary
        class="grid size-11 cursor-pointer list-none place-items-center rounded-lg border border-white/12 bg-white/6 text-white marker:hidden transition hover:border-seafoam/45"
        aria-label="Toggle menu"
      >
        <Menu class="size-5 group-open:hidden" aria-hidden="true" />
        <X class="hidden size-5 group-open:block" aria-hidden="true" />
      </summary>
      <nav
        class="absolute right-0 top-14 w-[min(84vw,22rem)] rounded-lg border border-white/12 bg-harbor p-3 shadow-lift"
        aria-label="Mobile navigation"
      >
        <div class="grid gap-1">
          {
            site.navLinks.map((link) => (
              <a
                href={withBase(link.href)}
                class:list={[
                  "rounded-lg px-4 py-3 text-base font-bold text-fog transition hover:bg-white/8 hover:text-white",
                  isActive(link.href) && "bg-white/8 text-white"
                ]}
              >
                {link.label}
              </a>
            ))
          }
          <a
            href={withBase("/book/")}
            class="mt-2 inline-flex min-h-12 items-center justify-center gap-2 rounded-lg bg-gold px-4 py-3 text-sm font-extrabold text-ink"
          >
            <CalendarDays class="size-4" aria-hidden="true" />
            <span>Book Now</span>
          </a>
        </div>
      </nav>
    </details>
  </div>
</header>

<style>
  .nav-preview {
    transition: none;
  }

  .nav-preview-item:hover .nav-preview,
  .nav-preview-item:focus-within .nav-preview {
    opacity: 1;
    transform: translate(-50%, 0);
    transition-delay: 0ms;
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-preview {
      transition: none;
    }
  }
</style>
