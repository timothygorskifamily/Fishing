---
import { site } from "@data/site";
import { phoneHref, withBase } from "@lib/links";
import { Anchor, CalendarDays, Menu, Phone, X } from "@lucide/astro";

const currentPath = Astro.url.pathname.replace(import.meta.env.BASE_URL, "/");
const isActive = (href: string) => {
  if (href === "/") {
    return currentPath === "/";
  }
  return currentPath.startsWith(href);
};
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-ink/82 backdrop-blur-xl">
  <div class="container-shell flex min-h-20 items-center justify-between gap-4">
    <a href={withBase("/")} class="group flex items-center gap-3" aria-label={`${site.businessName} home`}>
      <span
        class="grid size-11 place-items-center rounded-lg border border-seafoam/30 bg-seafoam/10 text-seafoam transition group-hover:border-seafoam/70"
        aria-hidden="true"
      >
        <Anchor class="size-5" />
      </span>
      <span class="min-w-0">
        <span class="block text-sm font-black leading-tight text-white md:text-base">
          {site.businessName}
        </span>
        <span class="block text-xs font-semibold uppercase tracking-[0.16em] text-mist">
          {site.shortLocation}
        </span>
      </span>
    </a>

    <nav class="hidden items-center gap-1 md:flex" aria-label="Primary navigation">
      {
        site.navLinks.map((link) => (
          <a
            href={withBase(link.href)}
            class:list={[
              "rounded-lg px-3 py-2 text-sm font-bold text-mist transition hover:bg-white/6 hover:text-white",
              isActive(link.href) && "bg-white/8 text-white"
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="hidden items-center gap-2 md:flex">
      <a
        href={phoneHref(site.phone)}
        class="inline-flex min-h-11 items-center justify-center gap-2 rounded-lg border border-white/12 px-4 py-2 text-sm font-extrabold text-fog transition hover:border-seafoam/45 hover:text-white"
      >
        <Phone class="size-4" aria-hidden="true" />
        <span>{site.phone}</span>
      </a>
      <a
        href={withBase("/book/")}
        class="inline-flex min-h-11 items-center justify-center gap-2 rounded-lg bg-gold px-4 py-2 text-sm font-extrabold text-ink transition hover:bg-[#ffd083]"
      >
        <CalendarDays class="size-4" aria-hidden="true" />
        <span>Book Now</span>
      </a>
    </div>

    <details class="group relative md:hidden">
      <summary
        class="grid size-11 cursor-pointer list-none place-items-center rounded-lg border border-white/12 bg-white/6 text-white marker:hidden transition hover:border-seafoam/45"
        aria-label="Toggle menu"
      >
        <Menu class="size-5 group-open:hidden" aria-hidden="true" />
        <X class="hidden size-5 group-open:block" aria-hidden="true" />
      </summary>
      <nav
        class="absolute right-0 top-14 w-[min(84vw,22rem)] rounded-lg border border-white/12 bg-harbor p-3 shadow-lift"
        aria-label="Mobile navigation"
      >
        <div class="grid gap-1">
          {
            site.navLinks.map((link) => (
              <a
                href={withBase(link.href)}
                class:list={[
                  "rounded-lg px-4 py-3 text-base font-bold text-fog transition hover:bg-white/8 hover:text-white",
                  isActive(link.href) && "bg-white/8 text-white"
                ]}
              >
                {link.label}
              </a>
            ))
          }
          <a
            href={withBase("/book/")}
            class="mt-2 inline-flex min-h-12 items-center justify-center gap-2 rounded-lg bg-gold px-4 py-3 text-sm font-extrabold text-ink"
          >
            <CalendarDays class="size-4" aria-hidden="true" />
            <span>Book Now</span>
          </a>
        </div>
      </nav>
    </details>
  </div>
</header>
