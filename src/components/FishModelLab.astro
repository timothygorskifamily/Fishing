---
import { ChevronLeft, ChevronRight, RotateCw, Scan, ZoomIn, ZoomOut } from "@lucide/astro";
import { site } from "@data/site";

const modelSpecies = site.fishSpecies.map((fish) => ({
  name: fish.name,
  aka: fish.aka ?? "",
  image: fish.image,
  specimenImage: fish.specimenImage ?? "",
  category: fish.category,
  typicalSize: fish.typicalSize,
  highSize: fish.highSize,
  season: fish.season,
  notes: fish.notes,
  modelSrc: fish.modelSrc ?? "",
  modelCredit: fish.modelCredit ?? "",
  modelLicense: fish.modelLicense ?? "",
  modelSourceUrl: fish.modelSourceUrl ?? ""
}));
---

<section
  id="fish-models"
  class="scroll-mt-24 border-y border-white/10 bg-[radial-gradient(circle_at_20%_10%,rgba(53,224,202,0.16),transparent_28rem),linear-gradient(180deg,#071821,#061016)] section-pad"
  data-fish-lab
>
  <script type="application/json" id="fish-model-data" set:html={JSON.stringify(modelSpecies)} />

  <div class="container-shell">
    <div class="grid gap-8 lg:grid-cols-[0.88fr_1.12fr] lg:items-end">
      <div>
        <p class="eyebrow mb-3">Interactive fish lab</p>
        <h2 class="text-balance font-display text-3xl font-black leading-tight text-white md:text-5xl">
          3D models of common Ocean City targets.
        </h2>
        <p class="mt-4 max-w-2xl text-base leading-8 text-mist">
          Detailed interactive models for the species OCGS commonly talks about: flounder, rockfish,
          bluefish, tog, sheepshead, drum, croaker, and bowfishing targets.
        </p>
      </div>

      <div class="grid gap-3 rounded-lg border border-white/12 bg-white/5 p-4 md:grid-cols-3">
        <div>
          <p class="text-xs font-black uppercase tracking-[0.16em] text-mist">Selected</p>
          <p class="mt-2 text-2xl font-black text-white" data-fish-name>Flounder</p>
          <p class="mt-1 text-sm font-bold text-seafoam" data-fish-aka>Summer flounder</p>
        </div>
        <div>
          <p class="text-xs font-black uppercase tracking-[0.16em] text-mist">Typical</p>
          <p class="mt-2 text-lg font-black text-white" data-fish-typical>16-22 in / 1-4 lb</p>
        </div>
        <div>
          <p class="text-xs font-black uppercase tracking-[0.16em] text-mist">Larger fish</p>
          <p class="mt-2 text-lg font-black text-gold" data-fish-high>26-30+ in / 6-10+ lb</p>
        </div>
      </div>
    </div>

    <div class="mt-8 grid gap-5 lg:grid-cols-[17rem_1fr]">
      <div class="card order-2 p-3 lg:order-1">
        <div class="grid gap-2" data-fish-buttons>
          {
            modelSpecies.map((fish, index) => (
              <button
                type="button"
                class:list={[
                  "rounded-lg border px-4 py-3 text-left transition",
                  index === 0
                    ? "border-seafoam/60 bg-seafoam/[0.14] text-white"
                    : "border-white/10 bg-white/[0.04] text-mist hover:border-seafoam/40 hover:text-white"
                ]}
                aria-pressed={index === 0 ? "true" : "false"}
                data-fish-select={index}
              >
                <span class="block text-sm font-black">{fish.name}</span>
                <span class="mt-1 block text-xs font-bold text-mist">{fish.category}</span>
              </button>
            ))
          }
        </div>
      </div>

      <div class="relative order-1 min-h-[620px] overflow-hidden rounded-lg border border-white/12 bg-[#061016] shadow-lift md:min-h-[700px] lg:order-2">
        <canvas
          class="absolute inset-0 h-full w-full touch-none"
          data-fish-canvas
          aria-label="Interactive 3D fish model viewer"
        ></canvas>

        <div class="pointer-events-none absolute inset-x-0 top-0 z-10 bg-gradient-to-b from-ink/86 to-transparent p-5">
          <p class="text-xs font-black uppercase tracking-[0.16em] text-aqua" data-fish-category>
            Bay / inlet
          </p>
          <p class="mt-2 max-w-2xl text-sm leading-7 text-fog" data-fish-notes>
            A signature Ocean City inshore target and a natural fit for family bay trips.
          </p>
          <p class="mt-2 text-xs font-bold text-mist" data-fish-season>Spring through fall windows</p>
          <p class="mt-2 hidden text-xs font-bold text-seafoam" data-fish-model-credit></p>
        </div>

        <div class="absolute bottom-24 left-1/2 z-20 flex -translate-x-1/2 gap-2 rounded-lg border border-white/12 bg-ink/72 p-2 shadow-lift backdrop-blur md:bottom-5">
          <button
            type="button"
            class="grid size-11 place-items-center rounded-lg border border-white/12 bg-white/6 text-white transition hover:border-seafoam/50 hover:bg-white/12"
            title="Previous species"
            aria-label="Previous species"
            data-fish-prev
          >
            <ChevronLeft class="size-5" aria-hidden="true" />
          </button>
          <button
            type="button"
            class="grid size-11 place-items-center rounded-lg border border-white/12 bg-white/6 text-white transition hover:border-seafoam/50 hover:bg-white/12"
            title="Toggle auto rotate"
            aria-label="Toggle auto rotate"
            aria-pressed="true"
            data-fish-auto
          >
            <RotateCw class="size-5" aria-hidden="true" />
          </button>
          <button
            type="button"
            class="grid size-11 place-items-center rounded-lg border border-white/12 bg-white/6 text-white transition hover:border-seafoam/50 hover:bg-white/12"
            title="Reset view"
            aria-label="Reset view"
            data-fish-reset
          >
            <Scan class="size-5" aria-hidden="true" />
          </button>
          <button
            type="button"
            class="grid size-11 place-items-center rounded-lg border border-white/12 bg-white/6 text-white transition hover:border-seafoam/50 hover:bg-white/12"
            title="Zoom in"
            aria-label="Zoom in"
            data-fish-zoom-in
          >
            <ZoomIn class="size-5" aria-hidden="true" />
          </button>
          <button
            type="button"
            class="grid size-11 place-items-center rounded-lg border border-white/12 bg-white/6 text-white transition hover:border-seafoam/50 hover:bg-white/12"
            title="Zoom out"
            aria-label="Zoom out"
            data-fish-zoom-out
          >
            <ZoomOut class="size-5" aria-hidden="true" />
          </button>
          <button
            type="button"
            class="grid size-11 place-items-center rounded-lg border border-white/12 bg-white/6 text-white transition hover:border-seafoam/50 hover:bg-white/12"
            title="Next species"
            aria-label="Next species"
            data-fish-next
          >
            <ChevronRight class="size-5" aria-hidden="true" />
          </button>
        </div>

        <div
          class="absolute inset-x-4 bottom-24 z-20 hidden rounded-lg border border-gold/30 bg-ink/92 p-4 text-sm leading-6 text-fog shadow-lift md:left-auto md:right-6 md:w-96"
          data-fish-fallback
        >
          This browser could not start the 3D fish viewer. The species cards above still work.
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import {
    ACESFilmicToneMapping,
    Box3,
    BoxGeometry,
    BufferGeometry,
    CanvasTexture,
    CircleGeometry,
    ConeGeometry,
    Color,
    CylinderGeometry,
    DirectionalLight,
    DoubleSide,
    Float32BufferAttribute,
    Fog,
    GridHelper,
    Group,
    HemisphereLight,
    LineBasicMaterial,
    Mesh,
    MeshBasicMaterial,
    MeshPhysicalMaterial,
    MeshStandardMaterial,
    PerspectiveCamera,
    PlaneGeometry,
    Scene,
    Shape,
    ShapeGeometry,
    SphereGeometry,
    SRGBColorSpace,
    TorusGeometry,
    TextureLoader,
    Vector3,
    WebGLRenderer
  } from "three";
  import { OrbitControls } from "three/examples/jsm/controls/OrbitControls.js";
  import { GLTFLoader } from "three/examples/jsm/loaders/GLTFLoader.js";

  const THREE = {
    ACESFilmicToneMapping,
    Box3,
    BoxGeometry,
    BufferGeometry,
    CanvasTexture,
    CircleGeometry,
    ConeGeometry,
    Color,
    CylinderGeometry,
    DirectionalLight,
    DoubleSide,
    Float32BufferAttribute,
    Fog,
    GridHelper,
    Group,
    HemisphereLight,
    LineBasicMaterial,
    Mesh,
    MeshBasicMaterial,
    MeshPhysicalMaterial,
    MeshStandardMaterial,
    PerspectiveCamera,
    PlaneGeometry,
    Scene,
    Shape,
    ShapeGeometry,
    SphereGeometry,
    SRGBColorSpace,
    TorusGeometry,
    TextureLoader,
    Vector3,
    WebGLRenderer
  };

  const root = document.querySelector("[data-fish-lab]");
  const canvas = root?.querySelector("[data-fish-canvas]");
  const rawData = document.querySelector("#fish-model-data")?.textContent ?? "[]";
  const species = JSON.parse(rawData);
  const baseUrl = import.meta.env.BASE_URL || "/";
  const cleanBase = baseUrl.endsWith("/") ? baseUrl : `${baseUrl}/`;

  if (root instanceof HTMLElement && canvas instanceof HTMLCanvasElement && species.length) {
    initFishLab(root, canvas, species);
  }

  function initFishLab(root, canvas, species) {
    const fallback = root.querySelector("[data-fish-fallback]");
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const scene = new THREE.Scene();
    scene.fog = new THREE.Fog(0x061016, 10, 32);
    const gltfLoader = new GLTFLoader();

    const camera = new THREE.PerspectiveCamera(42, 1, 0.1, 100);
    camera.position.set(4.5, 2.4, 6.6);

    let renderer;
    try {
      renderer = new THREE.WebGLRenderer({
        canvas,
        antialias: true,
        alpha: true,
        powerPreference: "high-performance",
        preserveDrawingBuffer: true
      });
    } catch (_error) {
      fallback?.classList.remove("hidden");
      return;
    }

    renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));
    renderer.outputColorSpace = THREE.SRGBColorSpace;
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.08;

    const controls = new OrbitControls(camera, canvas);
    controls.enableDamping = true;
    controls.dampingFactor = 0.08;
    controls.enablePan = true;
    controls.screenSpacePanning = true;
    controls.minDistance = 3.2;
    controls.maxDistance = 11;
    controls.maxPolarAngle = Math.PI * 0.78;
    controls.minPolarAngle = Math.PI * 0.12;
    controls.target.set(0, 0.12, 0);
    controls.autoRotate = !reducedMotion;
    controls.autoRotateSpeed = 0.8;

    addScene(scene);

    let activeIndex = 0;
    let activeToken = 0;
    let activeModel = new THREE.Group();
    scene.add(activeModel);
    setActive(0, false);

    root.querySelectorAll("[data-fish-select]").forEach((button) => {
      button.addEventListener("click", () => {
        setActive(Number(button.getAttribute("data-fish-select") || 0));
      });
    });

    root.querySelector("[data-fish-prev]")?.addEventListener("click", () => {
      setActive((activeIndex - 1 + species.length) % species.length);
    });

    root.querySelector("[data-fish-next]")?.addEventListener("click", () => {
      setActive((activeIndex + 1) % species.length);
    });

    const autoButton = root.querySelector("[data-fish-auto]");
    autoButton?.addEventListener("click", () => {
      controls.autoRotate = !controls.autoRotate;
      autoButton.setAttribute("aria-pressed", String(controls.autoRotate));
      autoButton.classList.toggle("text-seafoam", controls.autoRotate);
    });

    root.querySelector("[data-fish-reset]")?.addEventListener("click", resetView);
    root.querySelector("[data-fish-zoom-in]")?.addEventListener("click", () => {
      camera.position.multiplyScalar(0.88);
      controls.update();
    });
    root.querySelector("[data-fish-zoom-out]")?.addEventListener("click", () => {
      camera.position.multiplyScalar(1.12);
      controls.update();
    });

    function setActive(index, shouldScroll = true) {
      activeIndex = index;
      activeToken += 1;
      const token = activeToken;
      scene.remove(activeModel);
      disposeGroup(activeModel);
      activeModel = createFishModel(species[activeIndex]);
      scene.add(activeModel);
      updatePanel(root, species[activeIndex], activeIndex);
      loadLicensedModel(species[activeIndex], token);
      resetView();
      if (shouldScroll && root.clientWidth < 640) {
        canvas.parentElement?.scrollIntoView({
          block: "center",
          behavior: reducedMotion ? "auto" : "smooth"
        });
      }
    }

    function loadLicensedModel(fish, token) {
      const src = String(fish.modelSrc || "").trim();
      if (!src) return;

      gltfLoader.load(
        modelAssetPath(src),
        (gltf) => {
          if (token !== activeToken) {
            disposeGroup(gltf.scene);
            return;
          }

          const importedModel = createImportedFishModel(gltf.scene, fish);
          scene.remove(activeModel);
          disposeGroup(activeModel);
          activeModel = importedModel;
          scene.add(activeModel);
        },
        undefined,
        () => {
          // Keep the procedural model visible if the licensed file is missing or malformed.
        }
      );
    }

    function resetView() {
      const isMobile = root.clientWidth < 640;
      camera.position.set(isMobile ? 5.2 : 4.5, isMobile ? 2.7 : 2.4, isMobile ? 7.6 : 6.6);
      controls.target.set(0, 0.12, 0);
      controls.update();
    }

    function resize() {
      const box = canvas.parentElement?.getBoundingClientRect();
      const width = Math.max(box?.width || root.clientWidth, 1);
      const height = Math.max(box?.height || 640, 1);
      camera.aspect = width / height;
      camera.updateProjectionMatrix();
      renderer.setSize(width, height, false);
      resetView();
    }

    const observer = new ResizeObserver(resize);
    observer.observe(canvas.parentElement || root);
    resize();

    let frameId = 0;
    function animate() {
      frameId = window.requestAnimationFrame(animate);
      activeModel.rotation.y += reducedMotion ? 0 : 0.0015;
      controls.update();
      renderer.render(scene, camera);
    }

    animate();

    window.addEventListener("pagehide", () => {
      window.cancelAnimationFrame(frameId);
      observer.disconnect();
      controls.dispose();
      renderer.dispose();
      disposeGroup(activeModel);
    });
  }

  function addScene(scene) {
    scene.add(new THREE.HemisphereLight(0xc4f4ff, 0x061016, 1.9));

    const key = new THREE.DirectionalLight(0xffd59a, 2.7);
    key.position.set(-4, 6, 5);
    scene.add(key);

    const rim = new THREE.DirectionalLight(0x35e0ca, 2);
    rim.position.set(5, 2.4, -6);
    scene.add(rim);

    const grid = new THREE.GridHelper(12, 12, 0x35e0ca, 0x35e0ca);
    grid.position.y = -1.25;
    grid.material = new THREE.LineBasicMaterial({
      color: 0x35e0ca,
      transparent: true,
      opacity: 0.15
    });
    scene.add(grid);

    const ringMaterial = new THREE.MeshBasicMaterial({
      color: 0xf3b85b,
      transparent: true,
      opacity: 0.2,
      side: THREE.DoubleSide
    });
    [1.8, 2.8, 3.8].forEach((radius) => {
      const ring = new THREE.Mesh(new THREE.TorusGeometry(radius, 0.006, 8, 120), ringMaterial);
      ring.rotation.x = -Math.PI / 2;
      ring.position.y = -1.23;
      scene.add(ring);
    });
  }

  function updatePanel(root, fish, activeIndex) {
    root.querySelector("[data-fish-name]").textContent = fish.name;
    root.querySelector("[data-fish-aka]").textContent = fish.aka || fish.category;
    root.querySelector("[data-fish-typical]").textContent = fish.typicalSize;
    root.querySelector("[data-fish-high]").textContent = fish.highSize;
    root.querySelector("[data-fish-category]").textContent = fish.category;
    root.querySelector("[data-fish-notes]").textContent = fish.notes;
    root.querySelector("[data-fish-season]").textContent = fish.season;

    const creditEl = root.querySelector("[data-fish-model-credit]");
    const creditParts = [fish.modelCredit, fish.modelLicense].filter(Boolean);
    if (creditEl) {
      creditEl.textContent = creditParts.length
        ? `3D model: ${creditParts.join(" | ")}`
        : "Interactive species concept model; add a licensed GLB in site config for launch-ready 3D";
      creditEl.classList.remove("hidden");
    }

    root.querySelectorAll("[data-fish-select]").forEach((button, index) => {
      const active = index === activeIndex;
      button.setAttribute("aria-pressed", String(active));
      button.classList.toggle("border-seafoam/60", active);
      button.classList.toggle("bg-seafoam/[0.14]", active);
      button.classList.toggle("text-white", active);
      button.classList.toggle("border-white/10", !active);
      button.classList.toggle("bg-white/[0.04]", !active);
      button.classList.toggle("text-mist", !active);
    });
  }

  function createFishModel(fish) {
    const key = fish.name.toLowerCase();
    if (key.includes("flounder")) return createFlounder(fish);
    if (key.includes("rockfish")) return createRockfish(fish);
    if (key.includes("bluefish")) return createBluefish(fish);
    if (key.includes("tautog")) return createTautog(fish);
    if (key.includes("sheepshead")) return createSheepshead(fish);
    if (key.includes("red drum")) return createRedDrum(fish);
    if (key.includes("croaker")) return createCroaker(fish);
    return createRay(fish);
  }

  function createImportedFishModel(model, fish) {
    normalizeImportedModel(model);

    if (isApproxFishModel(fish)) {
      polishImportedApproxModel(model);
      poseImportedApproxModel(model, fish);
      return model;
    }

    styleImportedScan(model, fish);

    const group = new THREE.Group();
    group.add(model);
    group.add(createImportedScanOverlay(fish));
    return group;
  }

  function isApproxFishModel(fish) {
    return String(fish.modelSrc || "").includes("_approx.glb");
  }

  function polishImportedApproxModel(model) {
    model.traverse((item) => {
      if (!item.isMesh || !item.material) return;
      const materials = Array.isArray(item.material) ? item.material : [item.material];
      const polished = materials.map((material) => {
        const clone = material.clone();
        if ("roughness" in clone) clone.roughness = Math.min(clone.roughness ?? 0.42, 0.46);
        if ("metalness" in clone) clone.metalness = Math.max(clone.metalness ?? 0.02, 0.02);
        if ("clearcoat" in clone) clone.clearcoat = Math.max(clone.clearcoat ?? 0.35, 0.45);
        if ("clearcoatRoughness" in clone) clone.clearcoatRoughness = 0.28;
        clone.needsUpdate = true;
        return clone;
      });
      item.material = Array.isArray(item.material) ? polished : polished[0];
    });
  }

  function poseImportedApproxModel(model, fish) {
    const modelPath = String(fish.modelSrc || "").toLowerCase();

    if (modelPath.includes("cownose_ray")) {
      model.rotation.x = -Math.PI / 2;
      model.rotation.z = Math.PI / 2;
      model.position.y -= 0.08;
      model.scale.multiplyScalar(1.06);
    }
  }

  function normalizeImportedModel(model) {
    const box = new THREE.Box3().setFromObject(model);
    const center = new THREE.Vector3();
    const size = new THREE.Vector3();
    box.getCenter(center);
    box.getSize(size);

    const largestSide = Math.max(size.x, size.y, size.z) || 1;
    const scale = 3.35 / largestSide;
    model.scale.setScalar(scale);
    model.position.set(-center.x * scale, -center.y * scale, -center.z * scale);

    model.traverse((item) => {
      if (item.isMesh) {
        item.frustumCulled = false;
        if (item.material) {
          const materials = Array.isArray(item.material) ? item.material : [item.material];
          materials.forEach((material) => {
            material.needsUpdate = true;
          });
        }
      }
    });
  }

  function styleImportedScan(model, fish) {
    const variant = scanVariant(fish);
    model.scale.set(
      model.scale.x * variant.scale.x,
      model.scale.y * variant.scale.y,
      model.scale.z * variant.scale.z
    );
    model.rotation.set(variant.rotation.x, variant.rotation.y, variant.rotation.z);
    model.position.y += variant.y;

    const tint = new THREE.Color(variant.tint);
    model.traverse((item) => {
      if (!item.isMesh || !item.material) return;
      const materials = Array.isArray(item.material) ? item.material : [item.material];
      const styled = materials.map((material) => {
        const clone = material.clone();
        if (clone.color) clone.color.lerp(tint, variant.tintStrength);
        if ("roughness" in clone) clone.roughness = Math.min(clone.roughness ?? 0.42, 0.42);
        if ("metalness" in clone) clone.metalness = Math.max(clone.metalness ?? 0.03, 0.03);
        if ("clearcoat" in clone) clone.clearcoat = Math.max(clone.clearcoat ?? 0.45, 0.55);
        if ("clearcoatRoughness" in clone) clone.clearcoatRoughness = 0.24;
        clone.needsUpdate = true;
        return clone;
      });
      item.material = Array.isArray(item.material) ? styled : styled[0];
    });
  }

  function createImportedScanOverlay(fish) {
    const variant = scanVariant(fish);
    const group = new THREE.Group();

    if (fish.specimenImage && variant.photoOpacity > 0) {
      group.add(createScanSpecimenPanels(fish.specimenImage, variant));
    }

    addScanSpeciesMarks(group, variant);
    return group;
  }

  function scanVariant(fish) {
    const key = fish.name.toLowerCase();
    const shared = {
      type: "croaker",
      tint: 0xffffff,
      tintStrength: 0.06,
      scale: { x: 0.95, y: 0.95, z: 0.95 },
      rotation: { x: 0, y: 0, z: 0 },
      y: 0,
      panelLength: 3.35,
      panelHeight: 1.0,
      panelDepth: 0.48,
      panelY: 0.02,
      photoOpacity: 0
    };

    if (key.includes("flounder")) {
      return {
        ...shared,
        type: "flounder",
        tint: 0x9f8056,
        tintStrength: 0.34,
        scale: { x: 1.03, y: 0.56, z: 1.32 },
        rotation: { x: 0, y: 0, z: -0.04 },
        y: -0.08,
        panelHeight: 1.32,
        panelDepth: 0.64,
        photoOpacity: 0
      };
    }

    if (key.includes("rockfish")) {
      return {
        ...shared,
        type: "rockfish",
        tint: 0xd6e0dc,
        tintStrength: 0.28,
        scale: { x: 1.18, y: 1.0, z: 1.0 },
        panelLength: 3.72,
        panelHeight: 1.08,
        panelDepth: 0.52,
        photoOpacity: 0
      };
    }

    if (key.includes("bluefish")) {
      return {
        ...shared,
        type: "bluefish",
        tint: 0x86c6cf,
        tintStrength: 0.32,
        scale: { x: 1.12, y: 0.92, z: 0.96 },
        panelLength: 3.58,
        panelHeight: 1.0,
        photoOpacity: 0
      };
    }

    if (key.includes("tautog")) {
      return {
        ...shared,
        type: "tautog",
        tint: 0x36422d,
        tintStrength: 0.45,
        scale: { x: 0.95, y: 1.2, z: 1.1 },
        panelLength: 3.15,
        panelHeight: 1.26,
        panelDepth: 0.54,
        photoOpacity: 0
      };
    }

    if (key.includes("sheepshead")) {
      return {
        ...shared,
        type: "sheepshead",
        tint: 0xe4e4dc,
        tintStrength: 0.38,
        scale: { x: 0.96, y: 1.26, z: 1.02 },
        panelLength: 3.18,
        panelHeight: 1.34,
        panelDepth: 0.51,
        photoOpacity: 0
      };
    }

    if (key.includes("red drum")) {
      return {
        ...shared,
        type: "red-drum",
        tint: 0xc9834e,
        tintStrength: 0.42,
        scale: { x: 1.14, y: 1.02, z: 1.02 },
        panelLength: 3.62,
        panelHeight: 1.06,
        panelDepth: 0.52,
        photoOpacity: 0
      };
    }

    return shared;
  }

  function createScanSpecimenPanels(photo, variant) {
    const group = new THREE.Group();
    const geometry = new THREE.PlaneGeometry(variant.panelLength, variant.panelHeight);
    [-1, 1].forEach((side) => {
      const panel = new THREE.Mesh(geometry.clone(), createPhotoMaterial(photo, variant.photoOpacity, side < 0));
      panel.userData.photoSkin = true;
      panel.position.set(0, variant.panelY, side * variant.panelDepth);
      panel.rotation.y = side < 0 ? Math.PI : 0;
      group.add(panel);
    });
    return group;
  }

  function addScanSpeciesMarks(group, variant) {
    const type = variant.type;
    const markerDepth = variant.panelDepth + 0.012;

    if (type === "rockfish") {
      const mat = scanMarkMaterial(0x121b20, 0.18);
      for (let i = 0; i < 6; i += 1) {
        addSidePlane(group, -0.1, -0.24 + i * 0.1, 2.85, 0.028, markerDepth, mat, 0.03);
      }
      return;
    }

    if (type === "bluefish") {
      addSidePlane(group, -0.02, 0.08, 2.75, 0.045, markerDepth, scanMarkMaterial(0x35e0ca, 0.18), 0.04);
      return;
    }

    if (type === "sheepshead") {
      const mat = scanMarkMaterial(0x05080b, 0.2);
      [-1.05, -0.55, -0.05, 0.46, 0.93].forEach((x, index) => {
        addSidePlane(group, x, 0.02, index === 0 ? 0.08 : 0.11, 0.92, markerDepth, mat, index % 2 ? -0.08 : 0.08);
      });
      return;
    }

    if (type === "red-drum") {
      addSideSpot(group, -1.12, -0.08, 0.1, markerDepth, scanMarkMaterial(0x05080b, 0.46));
      addSidePlane(group, 0.08, -0.02, 2.2, 0.035, markerDepth, scanMarkMaterial(0xf3b85b, 0.16), 0.03);
      return;
    }

    if (type === "croaker") return;

    if (type === "tautog" || type === "flounder") {
      const color = type === "croaker" ? 0x8b612a : type === "flounder" ? 0x322113 : 0x05080b;
      const opacity = type === "flounder" ? 0.18 : 0.16;
      const mat = scanMarkMaterial(color, opacity);
      const count = type === "flounder" ? 18 : 12;
      for (let i = 0; i < count; i += 1) {
        const x = -1.1 + ((i * 0.42) % 2.25);
        const y = -0.34 + ((i * 0.21) % 0.72);
        addSideSpot(group, x, y, 0.035 + (i % 3) * 0.014, markerDepth, mat);
      }
    }
  }

  function scanMarkMaterial(color, opacity) {
    return new THREE.MeshBasicMaterial({
      color,
      transparent: true,
      opacity,
      depthWrite: false,
      side: THREE.DoubleSide
    });
  }

  function addSidePlane(group, x, y, width, height, depth, material, rotationZ = 0) {
    [-1, 1].forEach((side) => {
      const mark = new THREE.Mesh(new THREE.PlaneGeometry(width, height), material);
      mark.position.set(x, y, side * depth);
      mark.rotation.y = side < 0 ? Math.PI : 0;
      mark.rotation.z = rotationZ * side;
      group.add(mark);
    });
  }

  function addSideSpot(group, x, y, radius, depth, material) {
    const geometry = new THREE.CircleGeometry(radius, 28);
    [-1, 1].forEach((side) => {
      const spot = new THREE.Mesh(geometry.clone(), material);
      spot.position.set(x, y, side * depth);
      spot.rotation.y = side < 0 ? Math.PI : 0;
      group.add(spot);
    });
  }

  function modelAssetPath(src) {
    if (src.startsWith("http")) return src;
    return `${cleanBase}${src.replace(/^\/+/, "")}`;
  }

  function imageAssetPath(fileName) {
    if (fileName.startsWith("http")) return fileName;
    return `${cleanBase}images/${fileName.replace(/^\/?(images\/)?/, "")}`;
  }

  function mats() {
    return {
      silver: material(0xd9e7e5, 0.36, 0.15),
      belly: material(0xf3f8f4, 0.48, 0.05),
      dark: material(0x071016, 0.52, 0.18),
      teal: material(0x35e0ca, 0.34, 0.16),
      blue: material(0x1a6b84, 0.38, 0.15),
      bronze: material(0xb97b44, 0.46, 0.08),
      red: material(0xb95838, 0.42, 0.08),
      olive: material(0x293424, 0.5, 0.12),
      black: material(0x05080b, 0.58, 0.2),
      gold: material(0xf3b85b, 0.42, 0.08),
      glass: new THREE.MeshPhysicalMaterial({
        color: 0x7de7ee,
        roughness: 0.18,
        metalness: 0.05,
        clearcoat: 0.8
      })
    };
  }

  function material(color, roughness, metalness) {
    return new THREE.MeshPhysicalMaterial({
      color,
      roughness,
      metalness,
      clearcoat: 0.55,
      clearcoatRoughness: 0.22
    });
  }

  function baseFish({
    bodyColor,
    topColor,
    length = 3.1,
    height = 0.82,
    width = 0.62,
    tailColor,
    finColor,
    skin = "silver",
    photo
  }) {
    const materials = mats();
    const group = new THREE.Group();

    const body = new THREE.Mesh(new THREE.SphereGeometry(1, 56, 28), bodyColor);
    body.scale.set(length * 0.5, height * 0.5, width * 0.5);
    group.add(body);

    const back = new THREE.Mesh(new THREE.SphereGeometry(1, 48, 18), topColor);
    back.scale.set(length * 0.48, height * 0.22, width * 0.51);
    back.position.y = height * 0.19;
    group.add(back);

    const head = new THREE.Mesh(new THREE.SphereGeometry(1, 40, 20), bodyColor);
    head.scale.set(length * 0.22, height * 0.43, width * 0.43);
    head.position.x = length * 0.38;
    group.add(head);

    const eyeMat = materials.black;
    [-1, 1].forEach((side) => {
      const eye = new THREE.Mesh(new THREE.SphereGeometry(0.045, 16, 10), eyeMat);
      eye.position.set(length * 0.53, height * 0.14, side * width * 0.28);
      group.add(eye);
    });

    group.add(createSkinPanels(skin, length, height, width));

    const tail = triangleMesh(0.72, 0.92, tailColor || topColor);
    tail.position.x = -length * 0.58;
    tail.rotation.z = Math.PI;
    group.add(tail);

    const dorsal = triangleMesh(1.2, 0.38, finColor || topColor);
    dorsal.position.set(-0.35, height * 0.56, 0);
    dorsal.rotation.z = -Math.PI / 2;
    group.add(dorsal);

    const bottomFin = triangleMesh(0.75, 0.26, finColor || bodyColor);
    bottomFin.position.set(-0.3, -height * 0.52, 0);
    bottomFin.rotation.z = Math.PI / 2;
    group.add(bottomFin);

    [-1, 1].forEach((side) => {
      const fin = triangleMesh(0.42, 0.28, finColor || bodyColor);
      fin.position.set(0.25, -height * 0.05, side * width * 0.45);
      fin.rotation.y = side * -0.9;
      fin.rotation.z = -0.2;
      group.add(fin);
    });

    if (photo) {
      softenProceduralGeometry(group, 0.24);
      group.add(createPhotoSkinPanels(photo, length, height, width));
    }

    return group;
  }

  function createFlounder(fish) {
    const materials = mats();
    const group = new THREE.Group();
    const body = new THREE.Mesh(new THREE.SphereGeometry(1, 64, 24), materials.bronze);
    body.scale.set(1.75, 0.12, 0.9);
    body.rotation.z = -0.04;
    group.add(body);

    const skin = new THREE.Mesh(createFlatfishShape(3.45, 1.7), createSkinMaterial("flounder"));
    skin.rotation.x = -Math.PI / 2;
    skin.position.y = 0.138;
    group.add(skin);

    if (fish.specimenImage) {
      const photoSkin = new THREE.Mesh(new THREE.PlaneGeometry(3.65, 1.95), createPhotoMaterial(fish.specimenImage, 0.96));
      photoSkin.userData.photoSkin = true;
      photoSkin.rotation.x = -Math.PI / 2;
      photoSkin.position.y = 0.154;
      group.add(photoSkin);
    }

    const edge = new THREE.Mesh(new THREE.TorusGeometry(1, 0.018, 8, 96), materials.gold);
    edge.scale.set(1.75, 0.12, 0.9);
    edge.rotation.x = Math.PI / 2;
    group.add(edge);

    const tail = triangleMesh(0.55, 0.52, materials.bronze);
    tail.position.x = -1.74;
    tail.rotation.z = Math.PI;
    tail.rotation.x = Math.PI / 2;
    group.add(tail);

    [0.55, 0.78].forEach((x) => {
      const eye = new THREE.Mesh(new THREE.SphereGeometry(0.055, 16, 12), materials.black);
      eye.position.set(x, 0.17, 0.22);
      group.add(eye);
    });

    for (let i = 0; i < 16; i += 1) {
      const spot = new THREE.Mesh(new THREE.SphereGeometry(0.035 + (i % 3) * 0.012, 12, 8), materials.dark);
      spot.position.set(-1.1 + (i % 6) * 0.42, 0.16, -0.45 + Math.floor(i / 6) * 0.32);
      spot.scale.y = 0.12;
      group.add(spot);
    }

    if (fish.specimenImage) softenProceduralGeometry(group, 0.2);
    group.rotation.x = -0.1;
    return group;
  }

  function createRockfish(fish) {
    const materials = mats();
    const group = baseFish({
      bodyColor: materials.silver,
      topColor: materials.blue,
      tailColor: materials.blue,
      finColor: materials.dark,
      length: 3.3,
      height: 0.76,
      width: 0.58,
      skin: "rockfish",
      photo: fish.specimenImage
    });
    addHorizontalStripes(group, 6, 0x18242a, 0.035, 3.0, 0.62);
    if (fish.specimenImage) softenProceduralGeometry(group, 0.14);
    return group;
  }

  function createBluefish(fish) {
    const materials = mats();
    const group = baseFish({
      bodyColor: materials.silver,
      topColor: materials.teal,
      tailColor: materials.blue,
      finColor: materials.blue,
      length: 3.1,
      height: 0.72,
      width: 0.55,
      skin: "bluefish",
      photo: fish.specimenImage
    });
    addGlowLine(group, materials.teal);
    if (fish.specimenImage) softenProceduralGeometry(group, 0.14);
    return group;
  }

  function createTautog(fish) {
    const materials = mats();
    const group = baseFish({
      bodyColor: materials.olive,
      topColor: materials.dark,
      tailColor: materials.olive,
      finColor: materials.dark,
      length: 2.85,
      height: 0.95,
      width: 0.66,
      skin: "tautog",
      photo: fish.specimenImage
    });
    const lips = new THREE.Mesh(new THREE.SphereGeometry(0.22, 24, 12), materials.belly);
    lips.scale.set(0.72, 0.42, 0.5);
    lips.position.set(1.45, -0.02, 0);
    group.add(lips);
    addSpotPattern(group, materials.black, 12);
    if (fish.specimenImage) softenProceduralGeometry(group, 0.14);
    return group;
  }

  function createSheepshead(fish) {
    const materials = mats();
    const group = baseFish({
      bodyColor: materials.silver,
      topColor: materials.dark,
      tailColor: materials.dark,
      finColor: materials.dark,
      length: 2.8,
      height: 1.05,
      width: 0.56,
      skin: "sheepshead",
      photo: fish.specimenImage
    });
    addVerticalBars(group, 5, materials.black, 0.11, 1.0, 0.62);
    if (fish.specimenImage) softenProceduralGeometry(group, 0.14);
    return group;
  }

  function createRedDrum(fish) {
    const materials = mats();
    const group = baseFish({
      bodyColor: materials.red,
      topColor: materials.bronze,
      tailColor: materials.bronze,
      finColor: materials.red,
      length: 3.2,
      height: 0.78,
      width: 0.56,
      skin: "red-drum",
      photo: fish.specimenImage
    });
    const spot = new THREE.Mesh(new THREE.SphereGeometry(0.09, 18, 10), materials.black);
    spot.position.set(-1.22, 0.02, 0.31);
    spot.scale.z = 0.16;
    group.add(spot);
    addGlowLine(group, materials.gold);
    if (fish.specimenImage) softenProceduralGeometry(group, 0.14);
    return group;
  }

  function createCroaker(fish) {
    const materials = mats();
    const group = baseFish({
      bodyColor: materials.belly,
      topColor: materials.bronze,
      tailColor: materials.bronze,
      finColor: materials.gold,
      length: 2.55,
      height: 0.68,
      width: 0.48,
      skin: "croaker",
      photo: fish.specimenImage
    });
    addSpotPattern(group, materials.gold, 10);
    if (fish.specimenImage) softenProceduralGeometry(group, 0.14);
    return group;
  }

  function createRay(fish) {
    const materials = mats();
    const group = new THREE.Group();
    const shape = new THREE.Shape();
    shape.moveTo(0, 1.35);
    shape.bezierCurveTo(1.55, 0.85, 1.78, -0.12, 0, -1.05);
    shape.bezierCurveTo(-1.78, -0.12, -1.55, 0.85, 0, 1.35);

    const disc = new THREE.Mesh(new THREE.ShapeGeometry(shape, 40), materials.bronze);
    disc.rotation.x = -Math.PI / 2;
    disc.scale.set(1.18, 1.18, 1);
    group.add(disc);

    const raySkin = new THREE.Mesh(new THREE.ShapeGeometry(shape, 40), createSkinMaterial("ray"));
    raySkin.rotation.x = -Math.PI / 2;
    raySkin.position.y = 0.014;
    raySkin.scale.set(1.2, 1.2, 1);
    group.add(raySkin);

    if (fish?.specimenImage) {
      const photoSkin = new THREE.Mesh(new THREE.PlaneGeometry(3.3, 3.05), createPhotoMaterial(fish.specimenImage, 0.94));
      photoSkin.userData.photoSkin = true;
      photoSkin.rotation.x = -Math.PI / 2;
      photoSkin.position.y = 0.022;
      group.add(photoSkin);
    }

    const glow = new THREE.Mesh(
      new THREE.ShapeGeometry(shape, 40),
      new THREE.MeshBasicMaterial({
        color: 0x35e0ca,
        transparent: true,
        opacity: 0.18,
        side: THREE.DoubleSide
      })
    );
    glow.rotation.x = -Math.PI / 2;
    glow.position.y = -0.055;
    glow.scale.set(1.34, 1.34, 1);
    group.add(glow);

    const belly = new THREE.Mesh(new THREE.ShapeGeometry(shape, 40), materials.belly);
    belly.rotation.x = -Math.PI / 2;
    belly.position.y = -0.04;
    belly.scale.set(0.78, 0.78, 1);
    group.add(belly);

    const tail = pipe(new THREE.Vector3(0, 0, -1.08), new THREE.Vector3(0, 0.02, -3.3), 0.025, materials.dark);
    group.add(tail);

    [-0.25, 0.25].forEach((x) => {
      const eye = new THREE.Mesh(new THREE.SphereGeometry(0.055, 16, 10), materials.black);
      eye.position.set(x, 0.08, 0.58);
      group.add(eye);
    });

    const centerRidge = new THREE.Mesh(new THREE.SphereGeometry(0.48, 24, 12), materials.bronze);
    centerRidge.scale.set(0.9, 0.14, 0.42);
    centerRidge.position.set(0, 0.08, 0.08);
    group.add(centerRidge);

    group.rotation.y = Math.PI / 2;
    if (fish?.specimenImage) softenProceduralGeometry(group, 0.18);
    return group;
  }

  function createSkinPanels(type, length, height, width) {
    const group = new THREE.Group();
    const geometry = createFishProfileShape(length * 1.03, height * 1.04);
    [-1, 1].forEach((side) => {
      const panel = new THREE.Mesh(geometry.clone(), createSkinMaterial(type, side < 0));
      panel.position.z = side * width * 0.515;
      panel.rotation.y = side < 0 ? Math.PI : 0;
      group.add(panel);
    });
    return group;
  }

  function createPhotoSkinPanels(photo, length, height, width) {
    const group = new THREE.Group();
    const geometry = new THREE.PlaneGeometry(length * 1.12, height * 1.72);
    [-1, 1].forEach((side) => {
      const panel = new THREE.Mesh(geometry.clone(), createPhotoMaterial(photo, 0.94, side < 0));
      panel.userData.photoSkin = true;
      panel.position.y = height * 0.04;
      panel.position.z = side * width * 0.585;
      panel.rotation.y = side < 0 ? Math.PI : 0;
      group.add(panel);
    });
    return group;
  }

  function softenProceduralGeometry(group, opacity) {
    group.traverse((item) => {
      if (!item.isMesh || item.userData.photoSkin || !item.material) return;
      const materials = Array.isArray(item.material) ? item.material : [item.material];
      const softened = materials.map((material) => {
        const clone = material.clone();
        clone.transparent = true;
        clone.opacity = Math.min(clone.opacity ?? 1, opacity);
        clone.depthWrite = false;
        return clone;
      });
      item.material = Array.isArray(item.material) ? softened : softened[0];
    });
  }

  function createPhotoMaterial(photo, opacity = 0.94, mirrored = false) {
    const texture = new THREE.TextureLoader().load(imageAssetPath(photo), (loadedTexture) => {
      loadedTexture.colorSpace = THREE.SRGBColorSpace;
      loadedTexture.center.set(0.5, 0.5);
      loadedTexture.repeat.set(mirrored ? -1 : 1, 1);
      loadedTexture.needsUpdate = true;
    });
    texture.colorSpace = THREE.SRGBColorSpace;
    texture.center.set(0.5, 0.5);
    texture.repeat.set(mirrored ? -1 : 1, 1);

    return new THREE.MeshBasicMaterial({
      map: texture,
      transparent: true,
      opacity,
      alphaTest: 0.08,
      side: THREE.DoubleSide,
      depthWrite: false
    });
  }

  function createFishProfileShape(length, height) {
    const shape = new THREE.Shape();
    const noseX = length * 0.51;
    const tailX = -length * 0.48;
    shape.moveTo(noseX, 0.02);
    shape.bezierCurveTo(length * 0.42, height * 0.36, length * 0.08, height * 0.5, tailX, height * 0.22);
    shape.bezierCurveTo(tailX - length * 0.05, height * 0.05, tailX - length * 0.05, -height * 0.05, tailX, -height * 0.22);
    shape.bezierCurveTo(length * 0.03, -height * 0.46, length * 0.38, -height * 0.34, noseX, -0.02);
    return new THREE.ShapeGeometry(shape, 72);
  }

  function createFlatfishShape(length, width) {
    const shape = new THREE.Shape();
    shape.moveTo(length * 0.48, 0);
    shape.bezierCurveTo(length * 0.34, width * 0.48, -length * 0.22, width * 0.52, -length * 0.48, width * 0.08);
    shape.bezierCurveTo(-length * 0.54, 0, -length * 0.54, 0, -length * 0.48, -width * 0.08);
    shape.bezierCurveTo(-length * 0.22, -width * 0.52, length * 0.34, -width * 0.48, length * 0.48, 0);
    return new THREE.ShapeGeometry(shape, 96);
  }

  function createSkinMaterial(type, mirrored = false) {
    const texture = new THREE.CanvasTexture(createFishTexture(type, mirrored));
    texture.colorSpace = THREE.SRGBColorSpace;
    const material = new THREE.MeshPhysicalMaterial({
      map: texture,
      transparent: true,
      roughness: 0.36,
      metalness: 0.04,
      clearcoat: 0.78,
      clearcoatRoughness: 0.2,
      side: THREE.DoubleSide
    });
    return material;
  }

  function createFishTexture(type, mirrored) {
    const canvas = document.createElement("canvas");
    canvas.width = 1024;
    canvas.height = 512;
    const ctx = canvas.getContext("2d");
    const palette = skinPalette(type);
    const xScale = mirrored ? -1 : 1;

    ctx.save();
    if (mirrored) {
      ctx.translate(canvas.width, 0);
      ctx.scale(-1, 1);
    }

    const gradient = ctx.createLinearGradient(0, 0, 0, canvas.height);
    gradient.addColorStop(0, palette.top);
    gradient.addColorStop(0.46, palette.mid);
    gradient.addColorStop(0.8, palette.belly);
    gradient.addColorStop(1, palette.belly);
    ctx.fillStyle = gradient;
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    drawScaleField(ctx, palette.scale, type);
    drawLateralShading(ctx, palette.line);
    drawSpeciesMarks(ctx, type, palette);
    drawHeadAndEye(ctx, palette, xScale);

    ctx.restore();
    return canvas;
  }

  function skinPalette(type) {
    const palettes = {
      rockfish: {
        top: "#4e6870",
        mid: "#cfd8d6",
        belly: "#f5f2e7",
        line: "rgba(14, 27, 31, 0.72)",
        scale: "rgba(255,255,255,0.20)",
        mark: "rgba(9, 17, 22, 0.72)"
      },
      bluefish: {
        top: "#1b6f86",
        mid: "#9bc7c8",
        belly: "#eef1e8",
        line: "rgba(26, 89, 103, 0.72)",
        scale: "rgba(255,255,255,0.22)",
        mark: "rgba(41, 111, 130, 0.45)"
      },
      tautog: {
        top: "#101611",
        mid: "#38452c",
        belly: "#6c7453",
        line: "rgba(8, 12, 9, 0.7)",
        scale: "rgba(244,236,196,0.16)",
        mark: "rgba(0, 0, 0, 0.38)"
      },
      sheepshead: {
        top: "#202729",
        mid: "#e3e5dc",
        belly: "#f4f1e5",
        line: "rgba(28, 34, 36, 0.42)",
        scale: "rgba(255,255,255,0.18)",
        mark: "rgba(7, 10, 12, 0.86)"
      },
      "red-drum": {
        top: "#b5723f",
        mid: "#c8864f",
        belly: "#efe5c9",
        line: "rgba(123, 74, 41, 0.46)",
        scale: "rgba(255, 230, 174, 0.26)",
        mark: "rgba(7, 10, 12, 0.86)"
      },
      croaker: {
        top: "#b6955f",
        mid: "#d7c18c",
        belly: "#f0ead1",
        line: "rgba(117, 84, 44, 0.46)",
        scale: "rgba(255, 245, 205, 0.25)",
        mark: "rgba(96, 70, 32, 0.42)"
      },
      flounder: {
        top: "#776346",
        mid: "#9c8158",
        belly: "#c2a77a",
        line: "rgba(63, 47, 33, 0.52)",
        scale: "rgba(243, 217, 168, 0.18)",
        mark: "rgba(42, 30, 20, 0.68)"
      },
      ray: {
        top: "#7e6033",
        mid: "#b88743",
        belly: "#d7bd7e",
        line: "rgba(66, 44, 23, 0.46)",
        scale: "rgba(255, 230, 170, 0.18)",
        mark: "rgba(44, 29, 14, 0.48)"
      },
      silver: {
        top: "#557077",
        mid: "#d9e7e5",
        belly: "#f5f2e8",
        line: "rgba(30, 49, 52, 0.45)",
        scale: "rgba(255,255,255,0.2)",
        mark: "rgba(8, 16, 18, 0.45)"
      }
    };
    return palettes[type] || palettes.silver;
  }

  function drawScaleField(ctx, color, type) {
    ctx.strokeStyle = color;
    ctx.lineWidth = type === "flounder" || type === "ray" ? 1.2 : 1;
    const spacingX = type === "flounder" || type === "ray" ? 42 : 34;
    const spacingY = type === "flounder" || type === "ray" ? 34 : 28;
    for (let y = 74; y < 440; y += spacingY) {
      for (let x = 64; x < 940; x += spacingX) {
        ctx.beginPath();
        ctx.arc(x, y, spacingX * 0.38, Math.PI * 0.08, Math.PI * 0.92);
        ctx.stroke();
      }
    }
  }

  function drawLateralShading(ctx, color) {
    ctx.strokeStyle = color;
    ctx.lineWidth = 7;
    ctx.beginPath();
    ctx.moveTo(170, 260);
    ctx.bezierCurveTo(360, 230, 640, 236, 905, 252);
    ctx.stroke();

    ctx.strokeStyle = "rgba(255,255,255,0.22)";
    ctx.lineWidth = 4;
    ctx.beginPath();
    ctx.moveTo(130, 330);
    ctx.bezierCurveTo(350, 365, 680, 350, 930, 318);
    ctx.stroke();
  }

  function drawSpeciesMarks(ctx, type, palette) {
    if (type === "rockfish") {
      ctx.strokeStyle = palette.mark;
      ctx.lineWidth = 9;
      for (let i = 0; i < 7; i += 1) {
        ctx.beginPath();
        ctx.moveTo(110, 150 + i * 32);
        ctx.bezierCurveTo(360, 130 + i * 34, 630, 150 + i * 28, 930, 140 + i * 32);
        ctx.stroke();
      }
      return;
    }

    if (type === "sheepshead") {
      ctx.fillStyle = palette.mark;
      [185, 330, 485, 640, 790].forEach((x, i) => {
        ctx.save();
        ctx.translate(x, 256);
        ctx.rotate((i % 2 ? -1 : 1) * 0.08);
        ctx.fillRect(-22, -210, 54, 420);
        ctx.restore();
      });
      return;
    }

    if (type === "red-drum") {
      ctx.fillStyle = palette.mark;
      ctx.beginPath();
      ctx.arc(170, 268, 35, 0, Math.PI * 2);
      ctx.fill();
      ctx.fillStyle = "rgba(255, 232, 168, 0.45)";
      ctx.beginPath();
      ctx.arc(181, 258, 8, 0, Math.PI * 2);
      ctx.fill();
      return;
    }

    if (type === "tautog" || type === "croaker" || type === "flounder" || type === "ray") {
      ctx.fillStyle = palette.mark;
      const count = type === "flounder" ? 42 : type === "ray" ? 28 : 22;
      for (let i = 0; i < count; i += 1) {
        const x = 120 + ((i * 73) % 780);
        const y = 110 + ((i * 47) % 300);
        const r = type === "croaker" ? 9 : 7 + (i % 4) * 3;
        ctx.beginPath();
        ctx.ellipse(x, y, r * 1.4, r, 0.3, 0, Math.PI * 2);
        ctx.fill();
      }
      return;
    }

    if (type === "bluefish") {
      const glow = ctx.createLinearGradient(0, 210, 1024, 275);
      glow.addColorStop(0, "rgba(53, 224, 202, 0)");
      glow.addColorStop(0.5, "rgba(53, 224, 202, 0.42)");
      glow.addColorStop(1, "rgba(53, 224, 202, 0)");
      ctx.strokeStyle = glow;
      ctx.lineWidth = 18;
      ctx.beginPath();
      ctx.moveTo(90, 245);
      ctx.bezierCurveTo(340, 230, 680, 235, 950, 255);
      ctx.stroke();
    }
  }

  function drawHeadAndEye(ctx, palette) {
    const head = ctx.createRadialGradient(850, 210, 10, 830, 230, 170);
    head.addColorStop(0, "rgba(255,255,255,0.28)");
    head.addColorStop(1, "rgba(0,0,0,0.08)");
    ctx.fillStyle = head;
    ctx.fillRect(720, 42, 275, 430);

    ctx.fillStyle = "#05080b";
    ctx.beginPath();
    ctx.arc(842, 192, 21, 0, Math.PI * 2);
    ctx.fill();
    ctx.fillStyle = "#f1f7ee";
    ctx.beginPath();
    ctx.arc(849, 184, 6, 0, Math.PI * 2);
    ctx.fill();

    ctx.strokeStyle = palette.line;
    ctx.lineWidth = 5;
    ctx.beginPath();
    ctx.moveTo(900, 285);
    ctx.quadraticCurveTo(845, 300, 792, 284);
    ctx.stroke();
  }

  function addHorizontalStripes(group, count, color, thickness, length, width) {
    const mat = material(color, 0.5, 0.08);
    for (let i = 0; i < count; i += 1) {
      const stripe = new THREE.Mesh(new THREE.BoxGeometry(length, thickness, 0.018), mat);
      stripe.position.set(-0.05, -0.22 + i * 0.085, width * 0.5 + 0.02);
      stripe.rotation.z = 0.05;
      group.add(stripe);
    }
  }

  function addVerticalBars(group, count, mat, height, bodyHeight, width) {
    for (let i = 0; i < count; i += 1) {
      const bar = new THREE.Mesh(new THREE.BoxGeometry(0.08, bodyHeight, 0.02), mat);
      bar.position.set(-0.95 + i * 0.42, 0.01, width * 0.5 + 0.025);
      bar.rotation.z = -0.08;
      bar.scale.x = 1 + (i % 2) * 0.5;
      group.add(bar);
    }
  }

  function addGlowLine(group, mat) {
    const line = new THREE.Mesh(new THREE.BoxGeometry(2.55, 0.035, 0.024), mat);
    line.position.set(-0.08, -0.05, 0.31);
    group.add(line);
  }

  function addSpotPattern(group, mat, count) {
    for (let i = 0; i < count; i += 1) {
      const spot = new THREE.Mesh(new THREE.SphereGeometry(0.035 + (i % 2) * 0.012, 12, 8), mat);
      spot.position.set(-1.05 + (i % 5) * 0.42, -0.12 + Math.floor(i / 5) * 0.18, 0.35);
      spot.scale.z = 0.18;
      group.add(spot);
    }
  }

  function triangleMesh(width, height, material) {
    const geometry = new THREE.BufferGeometry();
    const verts = new Float32Array([0, 0, 0, -width, height * 0.5, 0, -width, -height * 0.5, 0]);
    geometry.setAttribute("position", new THREE.Float32BufferAttribute(verts, 3));
    geometry.setIndex([0, 1, 2]);
    geometry.computeVertexNormals();
    const mesh = new THREE.Mesh(geometry, material);
    mesh.material.side = THREE.DoubleSide;
    return mesh;
  }

  function pipe(start, end, radius, material) {
    const direction = new THREE.Vector3().subVectors(end, start);
    const length = direction.length();
    const geometry = new THREE.CylinderGeometry(radius, radius, length, 14);
    const mesh = new THREE.Mesh(geometry, material);
    mesh.position.copy(start).add(end).multiplyScalar(0.5);
    mesh.quaternion.setFromUnitVectors(new THREE.Vector3(0, 1, 0), direction.normalize());
    return mesh;
  }

  function disposeGroup(group) {
    group.traverse((item) => {
      if (item.geometry) item.geometry.dispose();
      if (item.material) {
        const materials = Array.isArray(item.material) ? item.material : [item.material];
        materials.forEach((material) => {
          Object.values(material).forEach((value) => {
            if (value && typeof value.dispose === "function") value.dispose();
          });
          material.dispose();
        });
      }
    });
  }
</script>
