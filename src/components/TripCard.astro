---
import CTAButton from "@components/CTAButton.astro";
import type { TripType } from "@data/site";
import { imagePath, withBase } from "@lib/links";
import { CalendarClock, CheckCircle2, Clock3, DollarSign } from "@lucide/astro";

interface Props {
  trip: TripType;
  compact?: boolean;
}

const { trip, compact = false } = Astro.props;
---

<article class="card noise-border grid overflow-hidden">
  <div class="image-sheen aspect-[16/10] bg-harbor">
    <img
      src={imagePath(trip.image)}
      alt={`${trip.name} image for an Ocean City fishing charter`}
      class:list={[
        "h-full w-full bg-white",
        trip.image === "young-angler-flounder.jpg" ? "object-contain" : "object-cover"
      ]}
      loading="lazy"
      decoding="async"
    />
  </div>
  <div class="grid gap-5 p-5 md:p-6">
    <div>
      <p class="eyebrow mb-2">{trip.eyebrow}</p>
      <h3 class="text-2xl font-black text-white">{trip.name}</h3>
      <p class="mt-3 text-sm leading-7 text-mist">{trip.description}</p>
    </div>

    <div class="grid gap-3 text-sm text-fog">
      <p class="flex items-start gap-2">
        <Clock3 class="mt-0.5 size-4 shrink-0 text-seafoam" aria-hidden="true" />
        <span><strong class="text-white">Duration:</strong> {trip.duration}</span>
      </p>
      <p class="flex items-start gap-2">
        <DollarSign class="mt-0.5 size-4 shrink-0 text-gold" aria-hidden="true" />
        <span><strong class="text-white">Rate:</strong> {trip.price}</span>
      </p>
      <p class="flex items-start gap-2">
        <CalendarClock class="mt-0.5 size-4 shrink-0 text-seafoam" aria-hidden="true" />
        <span><strong class="text-white">Trip time:</strong> {trip.times}</span>
      </p>
    </div>

    {!compact && (
      <div class="grid gap-4">
        <div>
          <h4 class="text-sm font-black uppercase tracking-[0.14em] text-white">Best For</h4>
          <p class="mt-2 text-sm leading-7 text-mist">{trip.bestFor}</p>
        </div>
        <div>
          <h4 class="text-sm font-black uppercase tracking-[0.14em] text-white">Target Species</h4>
          <div class="mt-3 flex flex-wrap gap-2">
            {trip.targetSpecies.map((species) => (
              <a
                href={withBase("/trips/#common-catches")}
                class="rounded-lg border border-seafoam/20 bg-seafoam/10 px-3 py-1 text-xs font-bold text-fog transition hover:border-seafoam/50 hover:text-white"
              >
                {species}
              </a>
            ))}
          </div>
        </div>
        <div>
          <h4 class="text-sm font-black uppercase tracking-[0.14em] text-white">Included</h4>
          <ul class="mt-3 grid gap-2 text-sm text-mist">
            {trip.included.map((item) => (
              <li class="flex gap-2">
                <CheckCircle2 class="mt-0.5 size-4 shrink-0 text-seafoam" aria-hidden="true" />
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    )}

    <CTAButton href="/book/" label="Request This Trip" icon="calendar" variant="secondary" full />
  </div>
</article>
