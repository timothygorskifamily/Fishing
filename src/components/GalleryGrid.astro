---
import type { GalleryImage } from "@data/site";
import { site } from "@data/site";
import { imagePath } from "@lib/links";

interface Props {
  images?: readonly GalleryImage[];
  limit?: number;
  minimal?: boolean;
}

const { images = site.galleryImages, limit, minimal = false } = Astro.props;
const visibleImages = limit ? images.slice(0, limit) : images;
---

<div class="columns-1 gap-5 sm:columns-2 lg:columns-3">
  {
    visibleImages.map((image, index) => (
      <figure class="mb-5 break-inside-avoid overflow-hidden rounded-lg border border-white/12 bg-white shadow-[0_18px_45px_rgba(16,80,103,0.12)] transition hover:-translate-y-1 hover:border-seafoam/45">
        <img
          src={imagePath(image.src)}
          alt={image.alt}
          class:list={[
            "w-full object-cover",
            minimal && "aspect-[4/3]",
            !minimal && (index % 3 === 0 ? "aspect-[4/5]" : index % 3 === 1 ? "aspect-[16/11]" : "aspect-[1/1]")
          ]}
          loading={minimal || index < 2 ? "eager" : "lazy"}
          decoding="async"
        />
      </figure>
    ))
  }
</div>
