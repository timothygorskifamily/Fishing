---
import CTAButton from "@components/CTAButton.astro";
import { site } from "@data/site";
import { calUrl, smsHref } from "@lib/links";

interface Props {
  calLink?: string;
}

const { calLink = site.calComLink } = Astro.props;
const elementId = "cal-booking-inline";
const bookingUrl = calUrl(calLink);
---

<section class="card noise-border overflow-hidden">
  <div class="grid gap-6 border-b border-white/10 bg-soft-horizon p-5 md:grid-cols-[1fr_auto] md:items-center md:p-7">
    <div>
      <p class="eyebrow mb-3">Live availability</p>
      <h2 class="text-balance text-3xl font-black leading-tight text-white md:text-4xl">
        Check Availability &amp; Request Your Date
      </h2>
      <p class="mt-4 max-w-3xl text-sm leading-7 text-fog md:text-base">
        Choose an available date and send your booking request. The captain will confirm trip details,
        weather, departure time, and final arrangements.
      </p>
    </div>
    <div class="flex flex-col gap-3 sm:flex-row md:flex-col">
      <CTAButton href={bookingUrl} label="Open Booking Calendar" icon="calendar" external />
      <CTAButton href={smsHref(site.smsPhone)} label="Call/Text Captain" icon="phone" variant="ghost" />
    </div>
  </div>

  <div class="bg-[#07151d] p-2 md:p-4">
    <div
      id={elementId}
      class="cal-embed min-h-[720px] rounded-lg border border-white/10 bg-white text-ink md:min-h-[780px]"
      data-cal-link={calLink}
    >
      <div class="grid min-h-[720px] place-items-center p-8 text-center md:min-h-[780px]">
        <div>
          <p class="text-lg font-black text-ink">Loading booking calendar...</p>
          <p class="mt-2 max-w-md text-sm leading-6 text-slate-600">
            If the calendar does not load, open the booking calendar directly or call/text the captain.
          </p>
        </div>
      </div>
    </div>
  </div>

  <div class="grid gap-2 border-t border-white/10 bg-ink/72 p-5 text-sm leading-7 text-mist md:p-6">
    <p><strong class="text-white">No payment is collected on this website.</strong> Final trip details are confirmed directly with the captain.</p>
    <p>Booking requests reserve availability pending captain confirmation.</p>
  </div>
</section>

<script define:vars={{ calLink, elementId }}>
  (function (C, A, L) {
    let p = function (a, ar) {
      a.q.push(ar);
    };
    let d = C.document;
    C.Cal =
      C.Cal ||
      function () {
        let cal = C.Cal;
        let ar = arguments;
        if (!cal.loaded) {
          cal.ns = {};
          cal.q = cal.q || [];
          d.head.appendChild(d.createElement("script")).src = A;
          cal.loaded = true;
        }
        if (ar[0] === L) {
          const api = function () {
            p(api, arguments);
          };
          const namespace = ar[1];
          api.q = api.q || [];
          if (typeof namespace === "string") {
            cal.ns[namespace] = cal.ns[namespace] || api;
            p(cal.ns[namespace], ar);
            p(cal, ["initNamespace", namespace]);
          } else p(cal, ar);
          return;
        }
        p(cal, ar);
      };
  })(window, "https://app.cal.com/embed/embed.js", "init");

  Cal("init", { origin: "https://cal.com" });
  Cal("inline", {
    elementOrSelector: `#${elementId}`,
    calLink,
    config: {
      layout: "month_view",
      theme: "dark"
    }
  });
  Cal("ui", {
    theme: "dark",
    hideEventTypeDetails: false,
    layout: "month_view",
    styles: {
      branding: {
        brandColor: "#35e0ca"
      }
    }
  });
</script>
