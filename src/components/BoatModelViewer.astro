---
import { Image as ImageIcon, RotateCw, Scan, ZoomIn, ZoomOut } from "@lucide/astro";
import { imagePath } from "@lib/links";

const runningImage = imagePath("boat-running.jpg");
---

<section
  class="relative min-h-[84svh] overflow-hidden border-y border-white/10 bg-[radial-gradient(circle_at_72%_22%,rgba(53,224,202,0.18),transparent_28rem),linear-gradient(180deg,#071821,#061016_74%)]"
  data-boat-model
  style={`--boat-photo: url("${runningImage}")`}
>
  <div
    class="absolute inset-0 bg-[image:var(--boat-photo)] bg-cover bg-center opacity-[0.36] saturate-90"
    aria-hidden="true"
  ></div>
  <div
    class="absolute inset-0 bg-[radial-gradient(circle_at_58%_42%,rgba(255,255,255,0.08),transparent_22rem),linear-gradient(90deg,rgba(6,16,22,0.94),rgba(6,16,22,0.52)_44%,rgba(6,16,22,0.88))]"
    aria-hidden="true"
  ></div>

  <canvas
    class="absolute inset-0 h-full w-full touch-none"
    data-boat-model-canvas
    aria-label="Interactive 3D model of a 29 foot SeaVee-style charter boat"
  ></canvas>

  <div class="pointer-events-none absolute inset-x-0 top-0 z-10 bg-[linear-gradient(180deg,rgba(6,16,22,0.98)_0%,rgba(6,16,22,0.94)_66%,rgba(6,16,22,0)_100%)]">
    <div class="container-shell py-8 md:py-10">
      <p class="eyebrow mb-3">360 concept model</p>
      <h1 class="max-w-3xl text-balance font-display text-3xl font-black leading-tight text-white sm:text-4xl md:text-6xl">
        29' SeaVee Concept
      </h1>
      <p class="mt-4 max-w-2xl text-sm leading-7 text-fog md:text-base">
        A photo-blended web model using the real Ocean City Guide Service SeaVee photos as visual reference.
      </p>
    </div>
  </div>

  <div class="absolute bottom-5 left-1/2 z-20 flex -translate-x-1/2 gap-2 rounded-lg border border-white/12 bg-ink/80 p-2 shadow-lift backdrop-blur">
    <button
      type="button"
      class="grid size-11 place-items-center rounded-lg border border-white/12 bg-white/6 text-white transition hover:border-seafoam/50 hover:bg-white/12"
      title="Toggle auto rotate"
      aria-label="Toggle auto rotate"
      aria-pressed="true"
      data-boat-auto
    >
      <RotateCw class="size-5" aria-hidden="true" />
    </button>
    <button
      type="button"
      class="grid size-11 place-items-center rounded-lg border border-white/12 bg-white/6 text-seafoam transition hover:border-seafoam/50 hover:bg-white/12"
      title="Toggle photo references"
      aria-label="Toggle photo references"
      aria-pressed="true"
      data-boat-photo
    >
      <ImageIcon class="size-5" aria-hidden="true" />
    </button>
    <button
      type="button"
      class="grid size-11 place-items-center rounded-lg border border-white/12 bg-white/6 text-white transition hover:border-seafoam/50 hover:bg-white/12"
      title="Reset view"
      aria-label="Reset view"
      data-boat-reset
    >
      <Scan class="size-5" aria-hidden="true" />
    </button>
    <button
      type="button"
      class="grid size-11 place-items-center rounded-lg border border-white/12 bg-white/6 text-white transition hover:border-seafoam/50 hover:bg-white/12"
      title="Zoom in"
      aria-label="Zoom in"
      data-boat-zoom-in
    >
      <ZoomIn class="size-5" aria-hidden="true" />
    </button>
    <button
      type="button"
      class="grid size-11 place-items-center rounded-lg border border-white/12 bg-white/6 text-white transition hover:border-seafoam/50 hover:bg-white/12"
      title="Zoom out"
      aria-label="Zoom out"
      data-boat-zoom-out
    >
      <ZoomOut class="size-5" aria-hidden="true" />
    </button>
  </div>

  <div
    class="absolute inset-x-4 bottom-24 z-20 hidden rounded-lg border border-gold/30 bg-ink/95 p-4 text-sm leading-6 text-fog shadow-lift md:left-auto md:right-6 md:w-96"
    data-model-fallback
  >
    This browser could not start the 3D viewer. The rest of the static site still works.
  </div>
</section>

<script>
  import {
    ACESFilmicToneMapping,
    BoxGeometry,
    BufferGeometry,
    CanvasTexture,
    CatmullRomCurve3,
    CircleGeometry,
    CylinderGeometry,
    DirectionalLight,
    DoubleSide,
    EllipseCurve,
    Float32BufferAttribute,
    Fog,
    GridHelper,
    Group,
    HemisphereLight,
    Line,
    LineBasicMaterial,
    Mesh,
    MeshBasicMaterial,
    MeshPhysicalMaterial,
    MeshStandardMaterial,
    PerspectiveCamera,
    PlaneGeometry,
    RepeatWrapping,
    Scene,
    Shape,
    ShapeGeometry,
    SRGBColorSpace,
    TorusGeometry,
    TextureLoader,
    TubeGeometry,
    Vector3,
    WebGLRenderer
  } from "three";
  import { OrbitControls } from "three/examples/jsm/controls/OrbitControls.js";

  const THREE = {
    ACESFilmicToneMapping,
    BoxGeometry,
    BufferGeometry,
    CanvasTexture,
    CatmullRomCurve3,
    CircleGeometry,
    CylinderGeometry,
    DirectionalLight,
    DoubleSide,
    EllipseCurve,
    Float32BufferAttribute,
    Fog,
    GridHelper,
    Group,
    HemisphereLight,
    Line,
    LineBasicMaterial,
    Mesh,
    MeshBasicMaterial,
    MeshPhysicalMaterial,
    MeshStandardMaterial,
    PerspectiveCamera,
    PlaneGeometry,
    RepeatWrapping,
    Scene,
    Shape,
    ShapeGeometry,
    SRGBColorSpace,
    TorusGeometry,
    TextureLoader,
    TubeGeometry,
    Vector3,
    WebGLRenderer
  };

  const baseUrl = import.meta.env.BASE_URL || "/";
  const cleanBase = baseUrl.endsWith("/") ? baseUrl : `${baseUrl}/`;

  const root = document.querySelector("[data-boat-model]");
  const canvas = root?.querySelector("[data-boat-model-canvas]");
  const fallback = root?.querySelector("[data-model-fallback]");

  if (root instanceof HTMLElement && canvas instanceof HTMLCanvasElement) {
    initBoatModel(root, canvas, fallback instanceof HTMLElement ? fallback : null);
  }

  function initBoatModel(root, canvas, fallback) {
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const scene = new THREE.Scene();
    scene.fog = new THREE.Fog(0x061016, 12, 34);

    const camera = new THREE.PerspectiveCamera(42, 1, 0.1, 100);
    camera.position.set(7.5, 4.5, 8.5);

    let renderer;
    try {
      renderer = new THREE.WebGLRenderer({
        canvas,
        antialias: true,
        alpha: true,
        powerPreference: "high-performance",
        preserveDrawingBuffer: true
      });
    } catch (_error) {
      fallback?.classList.remove("hidden");
      return;
    }

    renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));
    renderer.outputColorSpace = THREE.SRGBColorSpace;
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.05;

    const controls = new OrbitControls(camera, canvas);
    controls.enableDamping = true;
    controls.dampingFactor = 0.075;
    controls.enablePan = false;
    controls.minDistance = 6.5;
    controls.maxDistance = 15;
    controls.maxPolarAngle = Math.PI * 0.48;
    controls.minPolarAngle = Math.PI * 0.18;
    controls.target.set(0, 0.95, 0.2);
    controls.autoRotate = !reducedMotion;
    controls.autoRotateSpeed = 0.55;

    addLighting(scene);
    scene.add(createWater());
    const photoRefs = createPhotoReferences();
    const boat = createBoat();
    scene.add(photoRefs);
    scene.add(boat);
    scene.add(createReferenceRings());

    const autoButton = root.querySelector("[data-boat-auto]");
    const photoButton = root.querySelector("[data-boat-photo]");
    const resetButton = root.querySelector("[data-boat-reset]");
    const zoomInButton = root.querySelector("[data-boat-zoom-in]");
    const zoomOutButton = root.querySelector("[data-boat-zoom-out]");

    autoButton?.addEventListener("click", () => {
      controls.autoRotate = !controls.autoRotate;
      autoButton.setAttribute("aria-pressed", String(controls.autoRotate));
      autoButton.classList.toggle("text-seafoam", controls.autoRotate);
    });

    photoButton?.addEventListener("click", () => {
      photoRefs.visible = !photoRefs.visible;
      photoButton.setAttribute("aria-pressed", String(photoRefs.visible));
      photoButton.classList.toggle("text-seafoam", photoRefs.visible);
      photoButton.classList.toggle("text-white", !photoRefs.visible);
    });

    resetButton?.addEventListener("click", () => {
      camera.position.set(7.5, 4.5, 8.5);
      controls.target.set(0, 0.95, 0.2);
      controls.update();
    });

    zoomInButton?.addEventListener("click", () => {
      camera.position.multiplyScalar(0.88);
      controls.update();
    });

    zoomOutButton?.addEventListener("click", () => {
      camera.position.multiplyScalar(1.12);
      controls.update();
    });

    let mobileFraming = null;
    function resize() {
      const { clientWidth, clientHeight } = root;
      const isMobile = clientWidth < 640;
      if (mobileFraming !== isMobile) {
        mobileFraming = isMobile;
        if (isMobile) {
          camera.position.set(9.8, 5, 12.6);
          controls.target.set(0, 0.68, 0.12);
          controls.minDistance = 8.8;
          controls.maxDistance = 18;
        } else {
          camera.position.set(7.5, 4.5, 8.5);
          controls.target.set(0, 0.95, 0.2);
          controls.minDistance = 6.5;
          controls.maxDistance = 15;
        }
        controls.update();
      }
      camera.aspect = clientWidth / Math.max(clientHeight, 1);
      camera.updateProjectionMatrix();
      renderer.setSize(clientWidth, clientHeight, false);
    }

    const observer = new ResizeObserver(resize);
    observer.observe(root);
    resize();

    let frameId = 0;
    function animate() {
      frameId = window.requestAnimationFrame(animate);
      controls.update();
      renderer.render(scene, camera);
    }

    animate();

    window.addEventListener("pagehide", () => {
      window.cancelAnimationFrame(frameId);
      observer.disconnect();
      controls.dispose();
      renderer.dispose();
    });
  }

  function addLighting(scene) {
    scene.add(new THREE.HemisphereLight(0xbce8ff, 0x07151d, 1.9));

    const key = new THREE.DirectionalLight(0xffd6a0, 3.1);
    key.position.set(-6, 8, 5);
    scene.add(key);

    const rim = new THREE.DirectionalLight(0x35e0ca, 1.8);
    rim.position.set(7, 4, -6);
    scene.add(rim);
  }

  function materials() {
    const fiberglass = createFiberglassTexture();
    fiberglass.wrapS = THREE.RepeatWrapping;
    fiberglass.wrapT = THREE.RepeatWrapping;
    fiberglass.repeat.set(3.2, 1.4);

    return {
      hull: new THREE.MeshPhysicalMaterial({
        color: 0xf1f4ef,
        map: fiberglass,
        roughness: 0.28,
        metalness: 0.02,
        clearcoat: 0.95,
        clearcoatRoughness: 0.12
      }),
      deck: new THREE.MeshPhysicalMaterial({
        color: 0xf6f5ef,
        roughness: 0.42,
        metalness: 0.01,
        clearcoat: 0.4,
        clearcoatRoughness: 0.24
      }),
      accent: new THREE.MeshStandardMaterial({
        color: 0x183343,
        roughness: 0.32,
        metalness: 0.1
      }),
      seafoam: new THREE.MeshStandardMaterial({
        color: 0x35e0ca,
        roughness: 0.3,
        metalness: 0.12
      }),
      metal: new THREE.MeshStandardMaterial({
        color: 0xd8e6e4,
        roughness: 0.1,
        metalness: 0.9
      }),
      darkMetal: new THREE.MeshStandardMaterial({
        color: 0x17242c,
        roughness: 0.42,
        metalness: 0.55
      }),
      glass: new THREE.MeshPhysicalMaterial({
        color: 0x99e8ef,
        transparent: true,
        opacity: 0.34,
        roughness: 0.04,
        metalness: 0,
        transmission: 0.2
      }),
      black: new THREE.MeshStandardMaterial({
        color: 0x05080b,
        roughness: 0.38,
        metalness: 0.42,
        clearcoat: 0.7,
        clearcoatRoughness: 0.18
      }),
      cushion: new THREE.MeshStandardMaterial({
        color: 0xcfd8d6,
        roughness: 0.62,
        metalness: 0.03
      })
    };
  }

  function createBoat() {
    const mats = materials();
    const boat = new THREE.Group();
    boat.rotation.y = -0.14;
    boat.position.y = -0.1;

    boat.add(createHull(mats));
    boat.add(createDeck(mats));
    boat.add(createRubRails(mats));
    boat.add(createConsole(mats));
    boat.add(createTower(mats));
    boat.add(createLeaningPost(mats));
    boat.add(createOutboards(mats));
    boat.add(createDeckDetails(mats));
    boat.add(createRods(mats));
    boat.add(createDecals(mats));

    return boat;
  }

  function stations() {
    return [
      { z: -5.45, w: 0.08, chine: 0.02, keel: -0.88 },
      { z: -4.55, w: 0.92, chine: -0.16, keel: -0.98 },
      { z: -3.2, w: 1.48, chine: -0.28, keel: -1.02 },
      { z: -1.25, w: 1.86, chine: -0.34, keel: -1.04 },
      { z: 1.35, w: 1.93, chine: -0.32, keel: -0.98 },
      { z: 3.65, w: 1.82, chine: -0.26, keel: -0.86 },
      { z: 5.05, w: 1.64, chine: -0.18, keel: -0.72 }
    ];
  }

  function createHull(mats) {
    const verts = [];
    const indices = [];
    const ySheer = 0.48;

    stations().forEach((s) => {
      verts.push(
        -s.w,
        ySheer,
        s.z,
        -s.w * 0.86,
        s.chine,
        s.z,
        0,
        s.keel,
        s.z,
        s.w * 0.86,
        s.chine,
        s.z,
        s.w,
        ySheer,
        s.z
      );
    });

    const pointsPer = 5;
    for (let i = 0; i < stations().length - 1; i += 1) {
      for (let j = 0; j < pointsPer - 1; j += 1) {
        const a = i * pointsPer + j;
        const b = a + 1;
        const c = (i + 1) * pointsPer + j;
        const d = c + 1;
        indices.push(a, c, b, b, c, d);
      }
    }

    indices.push(0, 1, 2, 0, 2, 3, 0, 3, 4);
    const end = (stations().length - 1) * pointsPer;
    indices.push(end, end + 2, end + 1, end, end + 3, end + 2, end, end + 4, end + 3);

    const geometry = new THREE.BufferGeometry();
    geometry.setAttribute("position", new THREE.Float32BufferAttribute(verts, 3));
    geometry.setIndex(indices);
    geometry.computeVertexNormals();

    return new THREE.Mesh(geometry, mats.hull);
  }

  function createDeck(mats) {
    const verts = [];
    const indices = [];
    const y = 0.56;
    const sections = stations().map((s) => ({ z: s.z + 0.05, w: Math.max(s.w * 0.78, 0.04) }));

    sections.forEach((s) => {
      verts.push(-s.w, y, s.z, 0, y + 0.02, s.z, s.w, y, s.z);
    });

    for (let i = 0; i < sections.length - 1; i += 1) {
      const a = i * 3;
      const b = a + 1;
      const c = a + 2;
      const d = (i + 1) * 3;
      const e = d + 1;
      const f = d + 2;
      indices.push(a, d, b, b, d, e, b, e, c, c, e, f);
    }

    const geometry = new THREE.BufferGeometry();
    geometry.setAttribute("position", new THREE.Float32BufferAttribute(verts, 3));
    geometry.setIndex(indices);
    geometry.computeVertexNormals();

    return new THREE.Mesh(geometry, mats.deck);
  }

  function createRubRails(mats) {
    const group = new THREE.Group();
    const port = stations().map((s) => new THREE.Vector3(-s.w * 1.01, 0.52, s.z));
    const starboard = stations().map((s) => new THREE.Vector3(s.w * 1.01, 0.52, s.z));
    group.add(tube(port, 0.042, mats.black));
    group.add(tube(starboard, 0.042, mats.black));
    group.add(tube(port.map((p) => p.clone().setY(-0.44).multiplyScalar(0.94)), 0.028, mats.black));
    group.add(tube(starboard.map((p) => p.clone().setY(-0.44).multiplyScalar(0.94)), 0.028, mats.black));
    group.add(tube(port.map((p) => p.clone().setY(0.31)), 0.018, mats.seafoam));
    group.add(tube(starboard.map((p) => p.clone().setY(0.31)), 0.018, mats.seafoam));
    return group;
  }

  function createConsole(mats) {
    const group = new THREE.Group();

    const base = meshBox(1.18, 1.04, 1.34, mats.deck, 0, 1.05, -0.64);
    group.add(base);

    const brow = meshBox(1.26, 0.28, 0.62, mats.deck, 0, 1.62, -0.91);
    brow.rotation.x = -0.16;
    group.add(brow);

    const windshield = meshBox(1.02, 0.36, 0.05, mats.glass, 0, 1.72, -1.22);
    windshield.rotation.x = -0.22;
    group.add(windshield);

    const dash = meshBox(0.82, 0.28, 0.06, mats.black, 0, 1.35, -0.04);
    group.add(dash);

    const screens = [-0.23, 0.23].map((x) => meshBox(0.26, 0.16, 0.03, mats.glass, x, 1.4, -0.075));
    screens.forEach((screen) => group.add(screen));

    const wheel = new THREE.Mesh(new THREE.TorusGeometry(0.18, 0.018, 10, 30), mats.darkMetal);
    wheel.position.set(0, 1.22, 0.02);
    group.add(wheel);

    const rail = tube(
      [
        new THREE.Vector3(-0.66, 0.74, -1.25),
        new THREE.Vector3(-0.66, 1.6, -1.2),
        new THREE.Vector3(0.66, 1.6, -1.2),
        new THREE.Vector3(0.66, 0.74, -1.25)
      ],
      0.025,
      mats.metal
    );
    group.add(rail);

    return group;
  }

  function createTower(mats) {
    const group = new THREE.Group();
    const legs = [
      [-1.05, 0.58, -1.65, -1.18, 2.66, -1.46],
      [1.05, 0.58, -1.65, 1.18, 2.66, -1.46],
      [-1.0, 0.58, 0.82, -1.2, 2.66, 0.72],
      [1.0, 0.58, 0.82, 1.2, 2.66, 0.72],
      [-1.05, 0.85, -1.42, 1.05, 2.35, 0.64],
      [1.05, 0.85, -1.42, -1.05, 2.35, 0.64]
    ];

    legs.forEach(([x1, y1, z1, x2, y2, z2]) => {
      group.add(pipe(new THREE.Vector3(x1, y1, z1), new THREE.Vector3(x2, y2, z2), 0.028, mats.metal));
    });

    const platform = roundedPlate(2.45, 1.96, mats.darkMetal, 0, 2.67, -0.36, 0.24);
    group.add(platform);

    const top = roundedPlate(2.82, 2.34, mats.deck, 0, 3.08, -0.36, 0.28);
    group.add(top);

    const topEdge = [
      new THREE.Vector3(-1.28, 3.1, -1.35),
      new THREE.Vector3(1.28, 3.1, -1.35),
      new THREE.Vector3(1.36, 3.1, -0.36),
      new THREE.Vector3(1.28, 3.1, 0.7),
      new THREE.Vector3(-1.28, 3.1, 0.7),
      new THREE.Vector3(-1.36, 3.1, -0.36),
      new THREE.Vector3(-1.28, 3.1, -1.35)
    ];
    group.add(tube(topEdge, 0.026, mats.metal));

    const upperConsole = meshBox(0.82, 0.42, 0.5, mats.deck, 0, 2.96, -0.44);
    group.add(upperConsole);

    const upperWheel = new THREE.Mesh(new THREE.TorusGeometry(0.12, 0.012, 8, 24), mats.darkMetal);
    upperWheel.position.set(0, 2.96, -0.12);
    group.add(upperWheel);

    const railY = 2.95;
    const railPoints = [
      new THREE.Vector3(-1.22, railY, -1.28),
      new THREE.Vector3(1.22, railY, -1.28),
      new THREE.Vector3(1.22, railY, 0.6),
      new THREE.Vector3(-1.22, railY, 0.6),
      new THREE.Vector3(-1.22, railY, -1.28)
    ];
    group.add(tube(railPoints, 0.026, mats.metal));

    group.add(pipe(new THREE.Vector3(-1.15, 2.7, 0.72), new THREE.Vector3(-1.15, 3.42, 1.56), 0.014, mats.darkMetal));
    group.add(pipe(new THREE.Vector3(1.15, 2.7, 0.72), new THREE.Vector3(1.15, 3.42, 1.56), 0.014, mats.darkMetal));
    group.add(pipe(new THREE.Vector3(-0.3, 3.1, -1.1), new THREE.Vector3(-0.65, 4.15, -2.25), 0.012, mats.darkMetal));
    group.add(pipe(new THREE.Vector3(0.3, 3.1, -1.1), new THREE.Vector3(0.65, 4.15, -2.25), 0.012, mats.darkMetal));

    const radar = new THREE.Mesh(new THREE.CylinderGeometry(0.42, 0.42, 0.16, 32), mats.deck);
    radar.position.set(0, 3.23, -1.2);
    radar.rotation.z = Math.PI / 2;
    group.add(radar);

    [-0.86, -0.43, 0, 0.43, 0.86].forEach((x) => {
      group.add(pipe(new THREE.Vector3(x, 2.62, 0.86), new THREE.Vector3(x, 2.36, 1.18), 0.026, mats.metal));
    });

    return group;
  }

  function createLeaningPost(mats) {
    const group = new THREE.Group();
    group.add(meshBox(1.22, 0.52, 0.82, mats.deck, 0, 0.9, 1.02));
    group.add(meshBox(1.3, 0.16, 0.72, mats.cushion, 0, 1.23, 0.95));
    group.add(meshBox(1.02, 0.38, 0.55, mats.black, 0, 0.63, 1.46));

    [-0.48, -0.24, 0, 0.24, 0.48].forEach((x) => {
      group.add(pipe(new THREE.Vector3(x, 1.25, 1.48), new THREE.Vector3(x, 1.72, 1.74), 0.018, mats.metal));
    });

    return group;
  }

  function createOutboards(mats) {
    const group = new THREE.Group();
    [-0.43, 0.43].forEach((x) => {
      const motor = new THREE.Group();
      motor.position.set(x, 0, 5.42);
      motor.add(meshBox(0.5, 0.86, 0.42, mats.black, 0, 0.5, 0));
      motor.add(meshBox(0.3, 0.78, 0.18, mats.darkMetal, 0, -0.12, 0.1));
      motor.add(meshBox(0.18, 0.18, 0.5, mats.darkMetal, 0, -0.52, 0.18));
      const decal = textPlane("SUZUKI", 0.42, 0.15, "#ffffff", "rgba(0,0,0,0)");
      decal.position.set(0, 0.55, -0.22);
      decal.rotation.y = Math.PI;
      motor.add(decal);
      const number = textPlane("300", 0.3, 0.12, "#ffffff", "rgba(0,0,0,0)");
      number.position.set(0.26, 0.28, 0);
      number.rotation.y = Math.PI / 2;
      motor.add(number);
      const prop = new THREE.Mesh(new THREE.TorusGeometry(0.16, 0.012, 8, 24), mats.metal);
      prop.position.set(0, -0.5, 0.42);
      prop.rotation.y = Math.PI / 2;
      motor.add(prop);
      group.add(motor);
    });

    group.add(meshBox(1.45, 0.22, 0.18, mats.metal, 0, 0.2, 5.16));
    return group;
  }

  function createDeckDetails(mats) {
    const group = new THREE.Group();
    const hatchMaterial = new THREE.MeshBasicMaterial({
      color: 0x0a1f2a,
      transparent: true,
      opacity: 0.58
    });

    [
      [0, -3.45, 1.05, 0.86],
      [0, 2.75, 1.45, 0.82],
      [-0.92, -0.9, 0.34, 1.3],
      [0.92, -0.9, 0.34, 1.3]
    ].forEach(([x, z, sx, sz]) => {
      const hatch = new THREE.Mesh(new THREE.PlaneGeometry(sx, sz), hatchMaterial);
      hatch.rotation.x = -Math.PI / 2;
      hatch.position.set(x, 0.585, z);
      group.add(hatch);
    });

    group.add(meshBox(1.6, 0.12, 0.42, mats.cushion, 0, 0.68, -4.18));
    group.add(meshBox(1.48, 0.16, 0.5, mats.cushion, 0, 0.7, 3.94));

    [-1.34, 1.34].forEach((x) => {
      [-4.5, -1.2, 1.85, 4.3].forEach((z) => {
        const cleat = meshBox(0.18, 0.035, 0.08, mats.metal, x, 0.66, z);
        cleat.rotation.y = x < 0 ? -0.18 : 0.18;
        group.add(cleat);
      });
    });

    return group;
  }

  function createRods(mats) {
    const group = new THREE.Group();
    const rodPositions = [
      [-0.75, 1.54, 1.55, -1.25, 3.75, 2.85],
      [-0.38, 1.58, 1.63, -0.62, 3.92, 2.96],
      [0.38, 1.58, 1.63, 0.62, 3.92, 2.96],
      [0.75, 1.54, 1.55, 1.25, 3.75, 2.85],
      [-1.42, 0.67, 0.25, -1.62, 2.5, 1.55],
      [1.42, 0.67, 0.25, 1.62, 2.5, 1.55]
    ];

    rodPositions.forEach(([x1, y1, z1, x2, y2, z2]) => {
      group.add(pipe(new THREE.Vector3(x1, y1, z1), new THREE.Vector3(x2, y2, z2), 0.009, mats.black));
    });

    return group;
  }

  function createDecals() {
    const group = new THREE.Group();

    [
      { x: -1.78, ry: -Math.PI / 2 },
      { x: 1.78, ry: Math.PI / 2 }
    ].forEach(({ x, ry }) => {
      const logo = textPlane("SEA VEE", 0.72, 0.22, "#0a1118", "rgba(255,255,255,0)");
      logo.position.set(x, 0.04, 3.62);
      logo.rotation.y = ry;
      group.add(logo);
    });

    return group;
  }

  function createPhotoReferences() {
    const group = new THREE.Group();
    group.renderOrder = -1;

    group.add(
      photoPlane("images/boat-running.jpg", 11.4, 6.4, {
        position: new THREE.Vector3(-0.35, 2.12, 7.6),
        rotation: new THREE.Vector3(0, 0, 0),
        opacity: 0.2
      })
    );

    return group;
  }

  function photoPlane(src, width, height, { position, rotation, opacity }) {
    const texture = new THREE.TextureLoader().load(assetPath(src), (loaded) => {
      loaded.colorSpace = THREE.SRGBColorSpace;
    });
    texture.colorSpace = THREE.SRGBColorSpace;

    const material = new THREE.MeshBasicMaterial({
      map: texture,
      transparent: true,
      opacity,
      depthWrite: false,
      side: THREE.DoubleSide
    });
    const plane = new THREE.Mesh(new THREE.PlaneGeometry(width, height), material);
    plane.position.copy(position);
    plane.rotation.set(rotation.x, rotation.y, rotation.z);
    return plane;
  }

  function createWater() {
    const group = new THREE.Group();
    const plane = new THREE.Mesh(
      new THREE.CircleGeometry(18, 96),
      new THREE.MeshStandardMaterial({
        color: 0x0a4554,
        transparent: true,
        opacity: 0.48,
        roughness: 0.18,
        metalness: 0.22
      })
    );
    plane.rotation.x = -Math.PI / 2;
    plane.position.y = -0.98;
    group.add(plane);

    const ringMaterial = new THREE.LineBasicMaterial({
      color: 0x35e0ca,
      transparent: true,
      opacity: 0.18
    });
    [4.5, 7.5, 10.5, 13.5].forEach((radius) => {
      const curve = new THREE.EllipseCurve(0, 0, radius, radius * 0.42, 0, Math.PI * 2);
      const points = curve.getPoints(128).map((p) => new THREE.Vector3(p.x, -0.95, p.y));
      const line = new THREE.Line(new THREE.BufferGeometry().setFromPoints(points), ringMaterial);
      group.add(line);
    });

    const wakeMaterial = new THREE.MeshBasicMaterial({
      color: 0xffffff,
      transparent: true,
      opacity: 0.18,
      side: THREE.DoubleSide,
      depthWrite: false
    });

    [-0.75, 0.75].forEach((x) => {
      const wake = new THREE.Mesh(new THREE.PlaneGeometry(2.8, 0.36), wakeMaterial);
      wake.position.set(x, -0.91, 5.62);
      wake.rotation.x = -Math.PI / 2;
      wake.rotation.z = x < 0 ? -0.18 : 0.18;
      group.add(wake);
    });

    return group;
  }

  function createReferenceRings() {
    const group = new THREE.Group();
    const material = new THREE.LineBasicMaterial({
      color: 0xffffff,
      transparent: true,
      opacity: 0.08
    });
    const grid = new THREE.GridHelper(15, 15, 0x7de7ee, 0x7de7ee);
    grid.position.y = -0.94;
    grid.material = material;
    group.add(grid);
    return group;
  }

  function meshBox(width, height, depth, material, x, y, z) {
    const mesh = new THREE.Mesh(new THREE.BoxGeometry(width, height, depth), material);
    mesh.position.set(x, y, z);
    return mesh;
  }

  function roundedPlate(width, depth, material, x, y, z, radius) {
    const halfW = width / 2;
    const halfD = depth / 2;
    const r = Math.min(radius, halfW, halfD);
    const shape = new THREE.Shape();
    shape.moveTo(-halfW + r, -halfD);
    shape.lineTo(halfW - r, -halfD);
    shape.quadraticCurveTo(halfW, -halfD, halfW, -halfD + r);
    shape.lineTo(halfW, halfD - r);
    shape.quadraticCurveTo(halfW, halfD, halfW - r, halfD);
    shape.lineTo(-halfW + r, halfD);
    shape.quadraticCurveTo(-halfW, halfD, -halfW, halfD - r);
    shape.lineTo(-halfW, -halfD + r);
    shape.quadraticCurveTo(-halfW, -halfD, -halfW + r, -halfD);

    const mesh = new THREE.Mesh(new THREE.ShapeGeometry(shape, 32), material);
    mesh.rotation.x = -Math.PI / 2;
    mesh.position.set(x, y, z);
    return mesh;
  }

  function textPlane(text, width, height, color, background) {
    const canvas = document.createElement("canvas");
    canvas.width = 512;
    canvas.height = 160;
    const ctx = canvas.getContext("2d");
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    ctx.fillStyle = background;
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    ctx.fillStyle = color;
    ctx.font = "900 74px Arial, sans-serif";
    ctx.textAlign = "center";
    ctx.textBaseline = "middle";
    ctx.fillText(text, canvas.width / 2, canvas.height / 2 + 4);

    const texture = new THREE.CanvasTexture(canvas);
    texture.colorSpace = THREE.SRGBColorSpace;

    return new THREE.Mesh(
      new THREE.PlaneGeometry(width, height),
      new THREE.MeshBasicMaterial({
        map: texture,
        transparent: true,
        side: THREE.DoubleSide,
        depthWrite: false
      })
    );
  }

  function createFiberglassTexture() {
    const canvas = document.createElement("canvas");
    canvas.width = 384;
    canvas.height = 192;
    const ctx = canvas.getContext("2d");
    const gradient = ctx.createLinearGradient(0, 0, canvas.width, canvas.height);
    gradient.addColorStop(0, "#ffffff");
    gradient.addColorStop(0.45, "#eef3f0");
    gradient.addColorStop(1, "#f9faf6");
    ctx.fillStyle = gradient;
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    for (let i = 0; i < 900; i += 1) {
      const shade = 220 + Math.floor(Math.random() * 34);
      ctx.fillStyle = `rgba(${shade}, ${shade + 2}, ${shade + 4}, ${0.035 + Math.random() * 0.06})`;
      ctx.fillRect(Math.random() * canvas.width, Math.random() * canvas.height, 1.2, 1.2);
    }

    const texture = new THREE.CanvasTexture(canvas);
    texture.colorSpace = THREE.SRGBColorSpace;
    return texture;
  }

  function assetPath(path) {
    return `${cleanBase}${path.replace(/^\/+/, "")}`;
  }

  function pipe(start, end, radius, material) {
    const direction = new THREE.Vector3().subVectors(end, start);
    const length = direction.length();
    const geometry = new THREE.CylinderGeometry(radius, radius, length, 14);
    const mesh = new THREE.Mesh(geometry, material);
    mesh.position.copy(start).add(end).multiplyScalar(0.5);
    mesh.quaternion.setFromUnitVectors(new THREE.Vector3(0, 1, 0), direction.normalize());
    return mesh;
  }

  function tube(points, radius, material) {
    const curve = new THREE.CatmullRomCurve3(points, false, "centripetal");
    return new THREE.Mesh(new THREE.TubeGeometry(curve, 48, radius, 12, false), material);
  }
</script>
