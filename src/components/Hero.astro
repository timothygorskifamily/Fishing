---
import CTAButton from "@components/CTAButton.astro";
import { site } from "@data/site";
import { imagePath, smsHref } from "@lib/links";
---

<section class="relative min-h-[82svh] overflow-hidden border-b border-white/10">
  <img
    src={imagePath("hero-boat.jpg")}
    alt="Private center-console fishing charter boat running offshore near Ocean City, Maryland"
    class="absolute inset-0 h-full w-full object-cover"
    loading="eager"
    decoding="async"
    fetchpriority="high"
  />
  <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(6,16,22,0.92),rgba(6,16,22,0.66)_42%,rgba(6,16,22,0.22)),linear-gradient(180deg,rgba(6,16,22,0.20),rgba(6,16,22,0.90))]"></div>
  <div class="absolute inset-x-0 bottom-0 h-28 bg-gradient-to-t from-ink to-transparent"></div>

  <div class="container-shell relative flex min-h-[82svh] items-center py-16">
    <div class="max-w-3xl">
      <h1 class="text-balance font-display text-5xl font-black leading-[0.98] text-white md:text-7xl">
        Private Fishing Charters
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-fog md:text-xl">
        A clean {site.boatLength} {site.boatMake}, a private crew, and an easy day on the water.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <CTAButton href="/book/" label={site.primaryCTA} icon="calendar" />
        <CTAButton href={smsHref(site.smsPhone)} label={site.secondaryCTA} icon="phone" variant="ghost" />
      </div>
    </div>
  </div>
</section>
