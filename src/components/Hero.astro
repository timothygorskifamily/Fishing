---
import CTAButton from "@components/CTAButton.astro";
import { site } from "@data/site";
import { imagePath, smsHref } from "@lib/links";
---

<section class="overflow-hidden border-b border-white/10 bg-[#d9f4ff]">
  <div class="mx-auto grid max-w-[1500px] place-items-center px-2 py-2 md:px-5 md:py-5">
    <img
      src={imagePath("section-art/home-hero-current.png")}
      alt="Ocean City Guide Service SeaVee charter boat running on Ocean City water"
      class="max-h-[calc(100svh-13rem)] w-full object-contain"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
  </div>

  <div class="border-t border-sky-200/80 bg-white/90 px-4 py-4 shadow-[0_-16px_40px_rgba(6,45,68,0.08)] md:py-5">
    <div class="mx-auto grid w-full max-w-3xl gap-4">
      <div class="flex flex-col justify-center gap-3 sm:flex-row">
        <CTAButton href="/book/" label={site.primaryCTA} icon="calendar" />
        <CTAButton href={smsHref(site.smsPhone)} label={site.secondaryCTA} icon="phone" variant="secondary" />
      </div>
      <p class="mx-auto max-w-2xl text-center text-sm font-bold leading-7 text-mist md:text-base">
        {site.captainDescription}
      </p>
    </div>
  </div>
</section>
