---
import { site } from "@data/site";
import { CheckCircle2 } from "@lucide/astro";
---

<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
  {
    site.whatToBring.map((item) => (
      <article class="card p-5">
        <div class="mb-4 grid size-10 place-items-center rounded-lg border border-seafoam/25 bg-seafoam/10 text-seafoam">
          <CheckCircle2 class="size-5" aria-hidden="true" />
        </div>
        <h3 class="text-xl font-black text-white">{item.title}</h3>
        <p class="mt-3 text-sm leading-7 text-mist">{item.copy}</p>
      </article>
    ))
  }
</div>
