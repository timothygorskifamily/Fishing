---
import TripCard from "@components/TripCard.astro";
import { site } from "@data/site";

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
const tripsBySlug = new Map(site.tripTypes.map((trip) => [trip.slug, trip]));
---

<div class="grid gap-10">
  {
    site.tripGroups.map((group) => {
      const trips = group.tripSlugs.map((slug) => tripsBySlug.get(slug)).filter(Boolean);

      return (
        <section aria-labelledby={`trip-group-${group.title.toLowerCase().replace(/[^a-z0-9]+/g, "-")}`}>
          <div class="mb-5 max-w-2xl">
            <p class="eyebrow mb-2">{group.title}</p>
            <h3 id={`trip-group-${group.title.toLowerCase().replace(/[^a-z0-9]+/g, "-")}`} class="text-3xl font-black text-white">
              {group.title} trips
            </h3>
            <p class="mt-3 text-sm leading-7 text-mist md:text-base">{group.copy}</p>
          </div>
          <div class:list={["grid gap-5", compact ? "md:grid-cols-2 xl:grid-cols-3" : "lg:grid-cols-2"]}>
            {trips.map((trip) => trip && <TripCard trip={trip} compact={compact} />)}
          </div>
        </section>
      );
    })
  }
</div>
