---
import { site } from "@data/site";

const specs = [
  { label: "Length", value: site.boatLength },
  { label: "Make", value: site.boatMake },
  { label: "Layout", value: "Center-console" },
  { label: "Guests", value: "Up to 6" },
  { label: "Charter", value: "Private" }
];
---

<dl class="grid gap-3 sm:grid-cols-2 lg:grid-cols-5">
  {
    specs.map((spec) => (
      <div class="card p-5">
        <dt class="text-xs font-black uppercase tracking-[0.16em] text-mist">{spec.label}</dt>
        <dd class="mt-2 text-2xl font-black text-white">{spec.value}</dd>
      </div>
    ))
  }
</dl>
