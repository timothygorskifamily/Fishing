---
import { imagePath } from "@lib/links";

interface Props {
  title: string;
  mascot?: string;
  mascotAlt?: string;
  background?: string;
  backgroundPosition?: string;
  showTitle?: boolean;
}

const {
  title,
  background = "hero-boat.jpg",
  backgroundPosition = "center",
  showTitle = true
} = Astro.props;
---

<section class="relative isolate overflow-hidden border-b border-white/10 bg-[#d9f4ff]">
  <img
    src={imagePath(background)}
    alt=""
    class="absolute inset-0 h-full w-full scale-110 object-cover opacity-30 blur-2xl saturate-[1.12]"
    style={`object-position: ${backgroundPosition};`}
    loading="eager"
    decoding="async"
    aria-hidden="true"
  />
  <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(255,255,255,0.62),rgba(217,244,255,0.20)_42%,rgba(8,32,43,0.18))]"></div>

  <div class="relative mx-auto grid max-w-[1500px] place-items-center px-2 py-2 md:px-5 md:py-5">
    <img
      src={imagePath(background)}
      alt=""
      class="max-h-[min(72svh,46rem)] w-full object-contain drop-shadow-[0_24px_55px_rgba(6,45,68,0.18)]"
      style={`object-position: ${backgroundPosition};`}
      loading="eager"
      decoding="async"
      aria-hidden="true"
    />
    <h1
      class:list={[
        "page-header-title absolute text-center text-5xl font-black leading-none text-white drop-shadow-[0_4px_20px_rgba(0,0,0,0.58)] md:text-7xl",
        !showTitle && "sr-only"
      ]}
    >
      {title}
    </h1>
  </div>
</section>
