---
import { site } from "@data/site";
import { emailHref, phoneHref, withBase } from "@lib/links";
import { Anchor, Mail, MapPin, Phone } from "@lucide/astro";

const socials = [
  { label: "Instagram", href: site.instagramUrl },
  { label: "Facebook", href: site.facebookUrl },
  { label: "YouTube", href: site.youtubeUrl },
  { label: "TikTok", href: site.tiktokUrl }
];
---

<footer class="border-t border-white/10 bg-[#050c11] pb-24 pt-14 md:pb-10">
  <div class="container-shell">
    <div class="grid gap-10 lg:grid-cols-[1.25fr_0.75fr_0.75fr_0.9fr]">
      <div>
        <a href={withBase("/")} class="flex items-center gap-3">
          <span class="grid size-11 place-items-center rounded-lg border border-seafoam/30 bg-seafoam/10 text-seafoam">
            <Anchor class="size-5" aria-hidden="true" />
          </span>
          <span>
            <span class="block text-base font-black text-white">{site.businessName}</span>
            <span class="block text-xs font-semibold uppercase tracking-[0.16em] text-mist">
              {site.shortLocation}
            </span>
          </span>
        </a>
        <p class="mt-5 max-w-sm text-sm leading-7 text-mist">
          {site.tagline} Fish aboard a {site.boatLength} {site.boatMake} tower boat with simple
          scheduling and direct captain confirmation.
        </p>
      </div>

      <div>
        <h2 class="text-sm font-black uppercase tracking-[0.16em] text-white">Quick Links</h2>
        <ul class="mt-4 grid gap-3 text-sm text-mist">
          {site.navLinks.map((link) => <li><a class="hover:text-white" href={withBase(link.href)}>{link.label}</a></li>)}
          <li><a class="font-extrabold text-gold hover:text-[#ffd083]" href={withBase("/book/")}>Book Now</a></li>
        </ul>
      </div>

      <div>
        <h2 class="text-sm font-black uppercase tracking-[0.16em] text-white">Contact</h2>
        <ul class="mt-4 grid gap-3 text-sm text-mist">
          <li>
            <a class="inline-flex items-center gap-2 hover:text-white" href={phoneHref(site.phone)}>
              <Phone class="size-4 text-seafoam" aria-hidden="true" />
              {site.phone}
            </a>
          </li>
          <li>
            <a class="inline-flex items-center gap-2 hover:text-white" href={emailHref(site.email)}>
              <Mail class="size-4 text-seafoam" aria-hidden="true" />
              {site.email}
            </a>
          </li>
          <li>
            <a class="inline-flex items-center gap-2 hover:text-white" href={site.googleMapsUrl} target="_blank" rel="noreferrer">
              <MapPin class="size-4 text-seafoam" aria-hidden="true" />
              {site.marinaName}
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h2 class="text-sm font-black uppercase tracking-[0.16em] text-white">Social</h2>
        <div class="mt-4 flex flex-wrap gap-2">
          {
            socials.map((social) => (
              <a
                href={social.href}
                target={social.href === "#" ? undefined : "_blank"}
                rel={social.href === "#" ? undefined : "noreferrer"}
                class="inline-flex min-h-10 items-center justify-center rounded-lg border border-white/12 px-3 text-sm font-bold text-mist transition hover:border-seafoam/45 hover:text-white"
              >
                {social.label}
              </a>
            ))
          }
        </div>
      </div>
    </div>

    <div class="wave-rule my-10"></div>
    <div class="flex flex-col gap-3 text-xs text-mist md:flex-row md:items-center md:justify-between">
      <p>&copy; {new Date().getFullYear()} {site.businessName}. All rights reserved.</p>
      <p>Static site. Booking and calendar management happen through Cal.com.</p>
    </div>
  </div>
</footer>
