---
import { site } from "@data/site";
import { CheckCircle2 } from "@lucide/astro";

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<div class:list={["grid gap-4", compact ? "md:grid-cols-2 xl:grid-cols-5" : "md:grid-cols-2 lg:grid-cols-5"]}>
  {
    site.charterPolicies.map((policy) => (
      <article class="card p-5">
        <div class="mb-4 grid size-10 place-items-center rounded-lg border border-seafoam/25 bg-seafoam/10 text-seafoam">
          <CheckCircle2 class="size-5" aria-hidden="true" />
        </div>
        <h3 class="text-xl font-black text-white">{policy.title}</h3>
        <p class="mt-3 text-sm leading-7 text-mist">{policy.copy}</p>
      </article>
    ))
  }
</div>
