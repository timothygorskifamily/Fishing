---
import type { FishSpecies } from "@data/site";
import FishPhotoViewer from "@components/FishPhotoViewer.astro";
import FishSpinViewer from "@components/FishSpinViewer.astro";
import { site } from "@data/site";
import { imagePath } from "@lib/links";

interface Props {
  species?: readonly FishSpecies[];
  limit?: number;
}

const { species = site.fishSpecies, limit } = Astro.props;
const visibleSpecies = limit ? species.slice(0, limit) : species;
---

<div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
  {
    visibleSpecies.map((fish) => (
      <article class="card group overflow-hidden">
        {fish.imageFrames?.length ? (
          <FishPhotoViewer
            title={fish.name}
            frames={fish.imageFrames}
            alt={`${fish.name} photo gallery`}
          />
        ) : fish.spinFrames?.length ? (
          <FishSpinViewer
            title={fish.name}
            frames={fish.spinFrames}
            alt={`Interactive 360 viewer of ${fish.name}`}
          />
        ) : (
          <div class="image-sheen aspect-[4/3] bg-harbor">
            <img
              src={imagePath(fish.image)}
              alt={`${fish.name} caught on an Ocean City Maryland fishing charter`}
              class:list={[
                "h-full w-full transition duration-500 group-hover:scale-[1.04]",
                fish.image.startsWith("fish-spin/") ? "object-contain" : "object-cover"
              ]}
              loading="lazy"
              decoding="async"
            />
          </div>
        )}
        <div class="grid gap-4 p-5">
          <div>
            <p class="text-xs font-black uppercase tracking-[0.16em] text-seafoam">{fish.category}</p>
            <h3 class="mt-2 text-2xl font-black text-white">{fish.name}</h3>
            {fish.aka && <p class="mt-1 text-sm font-bold text-mist">{fish.aka}</p>}
          </div>

          <div class="rounded-lg border border-sky-100 bg-sky-50/80 p-3">
            <p class="text-xs font-black uppercase tracking-[0.12em] text-[#46717c]">Average range</p>
            <p class="mt-1 text-sm font-black text-ink">{fish.typicalSize}</p>
          </div>

          <p class="text-sm font-bold text-fog">{fish.season}</p>
          <p class="text-sm leading-7 text-mist">{fish.notes}</p>
        </div>
      </article>
    ))
  }
</div>
