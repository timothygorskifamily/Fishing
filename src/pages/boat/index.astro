---
import BoatSpecs from "@components/BoatSpecs.astro";
import PageHeader from "@components/PageHeader.astro";
import Layout from "@layouts/Layout.astro";
import { imagePath } from "@lib/links";

const boatImages = [
  {
    src: "boat-running.jpg",
    alt: "SeaVee running on coastal water"
  },
  {
    src: "boat-tower.jpg",
    alt: "Detail view of the SeaVee center-console boat"
  },
  {
    src: "deck.jpg",
    alt: "Clean center-console fishing deck"
  }
];
---

<Layout
  title="The Boat | 29' SeaVee in Ocean City MD"
  description="Meet the 29 foot SeaVee center console used for private Ocean City, Maryland fishing charters and sunset cruises."
  canonicalPath="/boat/"
>
  <PageHeader
    title="The Boat"
    mascot="boat-mascot.png"
    mascotAlt="A delighted fish mascot looking up at a center-console fishing boat"
    background="section-art/boat-section-title.webp"
    backgroundPosition="center top"
    showTitle={false}
  />

  <section class="section-pad">
    <div class="container-shell">
      <div class="grid gap-5 md:grid-cols-3">
        {
          boatImages.map((image) => (
            <figure class="card overflow-hidden">
              <img
                src={imagePath(image.src)}
                alt={image.alt}
                class="aspect-[4/3] w-full object-cover brightness-[1.06] saturate-[1.1] contrast-[1.02]"
                loading="lazy"
                decoding="async"
              />
            </figure>
          ))
        }
      </div>

      <div class="mt-8 md:mt-10">
        <BoatSpecs />
      </div>
    </div>
  </section>
</Layout>
