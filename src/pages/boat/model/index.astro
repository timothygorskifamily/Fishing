---
import BoatModelViewer from "@components/BoatModelViewer.astro";
import CTAButton from "@components/CTAButton.astro";
import SectionHeading from "@components/SectionHeading.astro";
import Layout from "@layouts/Layout.astro";
import { site } from "@data/site";
import { smsHref } from "@lib/links";

const referenceCues = [
  "Real OCGS SeaVee running and deck photos used as visual reference",
  "White SeaVee-style center-console hull with black rub rail and twin-outboard cues",
  "Open flush deck with hatch, leaning-post, and rod-holder details",
  "Photo-reference overlay can be toggled in the 360 viewer",
  "Still a lightweight web model, not a scanned CAD model"
];
---

<Layout
  title="3D Boat Model | 29' SeaVee Concept"
  description="Explore an original 360-degree 3D concept model inspired by a 29 foot 2006 SeaVee for an Ocean City, Maryland fishing charter."
  canonicalPath="/boat/model/"
  noIndex
>
  <BoatModelViewer />

  <section class="section-pad">
    <div class="container-shell grid gap-10 lg:grid-cols-[0.85fr_1.15fr]">
      <div>
        <SectionHeading
          eyebrow="Model notes"
          title="Photo-blended, editable, and still approximate."
          copy="This lightweight browser model now uses real Ocean City Guide Service boat photos as visual reference and background context. For true 1:1 accuracy, commission a scanned or CAD-based GLB model from the captain's boat."
        />
        <div class="flex flex-col gap-3 sm:flex-row">
          <CTAButton href="/book/" label="Check Availability" icon="calendar" />
          <CTAButton href={smsHref(site.smsPhone)} label="Call/Text Captain" icon="phone" variant="ghost" />
        </div>
      </div>

      <div class="grid gap-4">
        {
          referenceCues.map((cue) => (
            <div class="rounded-lg border border-white/12 bg-white/5 p-4 text-sm font-bold text-fog">
              {cue}
            </div>
          ))
        }
        <div class="rounded-lg border border-gold/24 bg-gold/10 p-5 text-sm leading-7 text-fog">
          <p>
            The visual model does not claim exact engines, electronics, seating, safety gear, passenger capacity,
            or rigging beyond what is visible in the current photos. Update those details only after the captain
            confirms final specifications.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
