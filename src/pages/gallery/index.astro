---
import CTAButton from "@components/CTAButton.astro";
import GalleryGrid from "@components/GalleryGrid.astro";
import SectionHeading from "@components/SectionHeading.astro";
import Layout from "@layouts/Layout.astro";
import { site } from "@data/site";
---

<Layout
  title="Gallery | Ocean City MD Fishing Reports & Boat Photos"
  description="View placeholder boat, catch, and Ocean City water photos for a private SeaVee fishing charter gallery."
  canonicalPath="/gallery/"
>
  <section class="border-b border-white/10 bg-harbor/50 section-pad">
    <div class="container-shell">
      <SectionHeading
        eyebrow="Gallery"
        title="Photo gallery and fishing report style updates."
        copy="This static gallery is built to feel like fishing reports without needing a CMS. Replace the placeholder files with real boat, catch, and crew photos."
      />
      <CTAButton href="/book/" label="Book A Day Like This" icon="calendar" />
    </div>
  </section>

  <section class="section-pad">
    <div class="container-shell">
      <div class="mb-8 rounded-lg border border-seafoam/20 bg-seafoam/8 p-5 text-sm leading-7 text-fog">
        <p>
          Photo placeholders live in <code class="rounded bg-white/8 px-1.5 py-0.5">public/images/</code>.
          Keep the same filenames to swap in real images without editing page code.
        </p>
      </div>
      <GalleryGrid />
    </div>
  </section>

  <section class="border-t border-white/10 bg-[#081720] py-16">
    <div class="container-shell grid gap-6 md:grid-cols-[1fr_auto] md:items-center">
      <div>
        <p class="eyebrow mb-3">Follow along</p>
        <h2 class="text-3xl font-black text-white md:text-4xl">See the latest catches on social.</h2>
        <p class="mt-3 max-w-2xl text-sm leading-7 text-mist">
          Connect Instagram, Facebook, TikTok, and YouTube links in the central site config when they are ready.
        </p>
      </div>
      <div class="flex flex-wrap gap-3">
        <CTAButton href={site.instagramUrl} label="Instagram" variant="ghost" external />
        <CTAButton href={site.facebookUrl} label="Facebook" variant="ghost" external />
      </div>
    </div>
  </section>
</Layout>
