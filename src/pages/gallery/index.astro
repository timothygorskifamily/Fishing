---
import GalleryGrid from "@components/GalleryGrid.astro";
import PageHeader from "@components/PageHeader.astro";
import { site } from "@data/site";
import { sourceGalleryImages } from "@data/sourceGallery";
import Layout from "@layouts/Layout.astro";

const normalizeGalleryLabel = (value: string) => value.toLowerCase().replace(/[^a-z0-9]/g, "");
const hiddenGalleryLabels = new Set(
  [
    "2015 01 03 13.06.46",
    "IMG 2671",
    "2014 12 27 10.02.51",
    "Dec9 1",
    "Dec9 4",
    "Dec9 5",
    "Sunset cruise",
    "short white black",
    "white cotton",
    "long white",
    "BD024A84 1D4C 4768 8310 1246382F0C6F",
    "salt life",
    "CD9166EF 1FBC 4238 8FB6 27D7B02A7EB5",
    "IMG 0048",
    "CRC 2326",
    "64ABF48E DC88 4A23 BE2C F4FB8D4D7C4E",
    "CRC 2633",
    "2015 01 22 11.13.10",
    "2013 01 16 10.23.51",
    "2013 01 16 11.41.04",
    "2013 01 17 17.37.13",
    "2013 01 17 17.38.00",
    "2013 01 17 17.38.07",
    "2013 01 17 17.38.12",
    "2013 01 18 11.11.47",
    "2013 01 19 08.34.28",
    "2013 01 19 09.28.41",
    "2015 01 07 12.08.50",
    "IMG 5872",
    "2015 01 07 12.08.52",
    "2015 01 17 10.23.59",
    "2015 01 20 15.10.58",
    "2015 01 23 08.26.15",
    "2015 01 29 10.42.19",
    "2015 01 29 10.42.37",
    "2015 01 29 10.42.39",
    "CRC 0435 2012 12 03 at 17 14 32",
    "DSC 1606",
    "bckg",
    "wlcomeOCGS",
    "sea rays",
    "fall winter",
    "jimmy",
    "featured",
    "81717 1",
    "2014 12 23 15.06.26",
    "10406989 10152904923821520 1195909264112858817 n"
  ].map(normalizeGalleryLabel)
);
const hiddenGalleryPrefixes = ["image1", "image3", "image5", "bowfishing", "wlcome", "81717", "bird", "duck", "seaduck", "gull"].map(normalizeGalleryLabel);
const duplicateGallerySources = new Set([
  "source-site/ocgs-1407-crc_4822-edit-edit.jpg",
  "source-site/ocgs-1406-crc_4792-edit-edit.jpg",
  "source-site/ocgs-1404-crc_4780-edit-edit.jpg",
  "source-site/ocgs-1275-photo-copy-2.jpg",
  "source-site/ocgs-998-11225278_831661573549989_1951854338364712173_n-2.jpg",
  "source-site/ocgs-999-11225278_831661573549989_1951854338364712173_n-3.jpg",
  "source-site/ocgs-986-crc_3163.jpg",
  "source-site/ocgs-929-crc_2904-2.jpg",
  "source-site/ocgs-1320-image4-4.jpeg",
  "source-site/ocgs-1379-img_0862-2.jpeg",
  "source-site/ocgs-1115-olympus-digital-camera-2.jpg"
]);
const towerBoatGallerySources = new Set([
  "fishingbooker/fishingbooker-01-boat-running.jpg",
  "boat-running.jpg",
  "deck.jpg",
  "boat-tower.jpg",
  "source-site/ocgs-500-dsc_1737.jpg",
  "source-site/ocgs-934-dsc_1550.jpg",
  "source-site/ocgs-939-dsc_1549-2.jpg",
  "source-site/ocgs-940-background.jpg",
  "source-site/ocgs-1110-img_06762.jpg",
  "source-site/ocgs-1403-crc_4712-edit.jpg",
  "source-site/ocgs-1404-crc_4780-edit-edit.jpg",
  "source-site/ocgs-1405-crc_4786-edit.jpg",
  "source-site/ocgs-1406-crc_4792-edit-edit.jpg",
  "source-site/ocgs-1407-crc_4822-edit-edit.jpg"
]);

const shouldHideGalleryImage = (image: typeof sourceGalleryImages[number] | typeof site.galleryImages[number]) => {
  const keys = [image.title, image.alt, image.src].map(normalizeGalleryLabel);
  return duplicateGallerySources.has(image.src) || towerBoatGallerySources.has(image.src) || keys.some(
    (key) =>
      hiddenGalleryLabels.has(key) ||
      hiddenGalleryPrefixes.some((prefix) => key.startsWith(prefix) || key.includes(`source${prefix}`))
  );
};

const galleryPriority = (image: typeof sourceGalleryImages[number]) => {
  const key = normalizeGalleryLabel(`${image.title} ${image.src}`);
  let score = 0;
  if (key.includes("hammerhead")) score += 100;
  if (key.includes("shark")) score += 90;
  if (key.includes("flounder")) score += 70;
  if (key.includes("rockfish") || key.includes("stripedbass")) score += 65;
  if (key.includes("seabass") || key.includes("tautog") || key.includes("bluefish")) score += 60;
  if (key.includes("catch") || key.includes("fish")) score += 35;
  if (key.includes("fullsizerender") || key.includes("photo")) score += 5;
  return score;
};

const curatedGalleryImages = site.galleryImages.filter((image) => !shouldHideGalleryImage(image));
const orderedSourceGalleryImages = sourceGalleryImages
  .filter((image) => !shouldHideGalleryImage(image))
  .sort((a, b) => galleryPriority(b) - galleryPriority(a) || a.title.localeCompare(b.title));
const allGalleryImages = [...curatedGalleryImages, ...orderedSourceGalleryImages];
---

<Layout
  title="Gallery | Ocean City MD Fishing Reports & Boat Photos"
  description="View boat, catch, and Ocean City water photos for a private SeaVee fishing charter gallery."
  canonicalPath="/gallery/"
>
  <PageHeader
    title="Gallery"
    background="charter-flounder-dock.jpg"
    backgroundPosition="center 35%"
  />

  <section class="section-pad">
    <div class="container-shell">
      <GalleryGrid images={allGalleryImages} />
    </div>
  </section>
</Layout>
