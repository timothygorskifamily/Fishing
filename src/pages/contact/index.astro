---
import ContactCards from "@components/ContactCards.astro";
import CTAButton from "@components/CTAButton.astro";
import SectionHeading from "@components/SectionHeading.astro";
import Layout from "@layouts/Layout.astro";
import { site } from "@data/site";
---

<Layout
  title="Contact | Ocean City Guide Service"
  description="Contact an Ocean City, Maryland private fishing charter by phone, text, email, social links, or map button."
  canonicalPath="/contact/"
>
  <section class="border-b border-white/10 bg-harbor/50 section-pad">
    <div class="container-shell grid gap-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-end">
      <SectionHeading
        eyebrow="Contact"
        title="Talk with the captain."
        copy="Fastest way to book: check the calendar, then call/text with questions. Final trip details are confirmed directly."
      />
      <div class="card p-5">
        <p class="text-sm font-black uppercase tracking-[0.16em] text-seafoam">Location</p>
        <p class="mt-3 text-2xl font-black text-white">{site.location}</p>
        <p class="mt-2 text-sm leading-7 text-mist">
          Current address: {site.marinaAddress}. Confirm exact parking, dock, and meeting details after booking.
        </p>
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-shell">
      <ContactCards />
    </div>
  </section>

  <section class="border-y border-white/10 bg-[#081720] py-16">
    <div class="container-shell grid gap-6 md:grid-cols-[1fr_auto] md:items-center">
      <div>
        <p class="eyebrow mb-3">Map</p>
        <h2 class="text-3xl font-black text-white md:text-4xl">Ocean City, Maryland</h2>
        <p class="mt-3 max-w-2xl text-sm leading-7 text-mist">
          Exact departure details are confirmed with the captain after booking request approval.
        </p>
      </div>
      <CTAButton href={site.googleMapsUrl} label="Open Map" variant="ghost" external />
    </div>
  </section>

  <section class="py-16">
    <div class="container-shell grid gap-6 rounded-lg border border-white/12 bg-soft-horizon p-6 md:grid-cols-[1fr_auto] md:items-center md:p-8">
      <div>
        <p class="eyebrow mb-3">Ready</p>
        <h2 class="text-3xl font-black text-white md:text-4xl">Check the calendar and request your date.</h2>
      </div>
      <CTAButton href="/book/" label="Check Availability" icon="calendar" />
    </div>
  </section>
</Layout>
