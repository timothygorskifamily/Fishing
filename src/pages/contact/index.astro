---
import ContactCards from "@components/ContactCards.astro";
import PageHeader from "@components/PageHeader.astro";
import Layout from "@layouts/Layout.astro";
---

<Layout
  title="Contact | Ocean City Guide Service"
  description="Contact an Ocean City, Maryland private fishing charter by phone, text, email, social links, or map button."
  canonicalPath="/contact/"
>
  <PageHeader
    title="Contact"
    mascot="contact-mascot.png"
    mascotAlt="A fish mascot holding a phone for the contact page"
    background="section-art/contact-section-title.webp"
    backgroundPosition="center top"
    showTitle={false}
  />

  <section class="border-b border-sky-100 bg-[radial-gradient(circle_at_50%_0%,rgba(53,224,202,0.18),transparent_34%),linear-gradient(180deg,rgba(255,255,255,0.72),rgba(232,248,252,0)_46%)] py-12 md:py-20">
    <div class="container-shell">
      <ContactCards />
    </div>
  </section>
</Layout>
