---
import CalBookingEmbed from "@components/CalBookingEmbed.astro";
import CharterPolicies from "@components/CharterPolicies.astro";
import CTAButton from "@components/CTAButton.astro";
import PageHeader from "@components/PageHeader.astro";
import SectionHeading from "@components/SectionHeading.astro";
import Layout from "@layouts/Layout.astro";
import { site } from "@data/site";
import { smsHref } from "@lib/links";
---

<Layout
  title="Book a Fishing Charter | Ocean City Guide Service"
  description="Check availability and request a private Ocean City, Maryland fishing charter date using the inline Cal.com booking calendar."
  canonicalPath="/book/"
>
  <PageHeader
    title="Book"
    mascot="book-mascot.png"
    mascotAlt="A fish mascot holding a blank calendar for booking"
  />

  <section class="section-pad">
    <div class="container-shell">
      <CalBookingEmbed calLink={site.calComLink} />
    </div>
  </section>

  <section class="border-t border-white/10 bg-white/5 section-pad">
    <div class="container-shell">
      <SectionHeading
        eyebrow="Before booking"
        title="Charter policies."
        copy="A quick check on deposits, cancellation, weather, payment, and mate tipping before you request a date."
      />
      <CharterPolicies compact />
    </div>
  </section>

  <section class="border-t border-white/10 bg-white/5 py-16">
    <div class="container-shell grid gap-6 md:grid-cols-[1fr_auto] md:items-center">
      <div>
        <p class="eyebrow mb-3">Questions first?</p>
        <h2 class="text-3xl font-black text-white md:text-4xl">Call or text before you request a date.</h2>
        <p class="mt-3 max-w-2xl text-sm leading-7 text-mist">
          Fastest way to book: check the calendar, then call/text with questions.
        </p>
      </div>
      <CTAButton href={smsHref(site.smsPhone)} label="Call/Text Captain" icon="phone" variant="ghost" />
    </div>
  </section>
</Layout>
