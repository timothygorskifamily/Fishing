---
import CalBookingEmbed from "@components/CalBookingEmbed.astro";
import CharterPolicies from "@components/CharterPolicies.astro";
import PageHeader from "@components/PageHeader.astro";
import SectionHeading from "@components/SectionHeading.astro";
import Layout from "@layouts/Layout.astro";
import { site } from "@data/site";
---

<Layout
  title="Book a Fishing Charter | Ocean City Guide Service"
  description="Check availability and request a private Ocean City, Maryland fishing charter date using the inline Cal.com booking calendar."
  canonicalPath="/book/"
>
  <PageHeader
    title="Book"
    mascot="book-mascot.png"
    mascotAlt="A fish mascot holding a blank calendar for booking"
    background="section-art/book-section-title.png"
    backgroundPosition="center top"
    showTitle={false}
  />

  <section class="section-pad">
    <div class="container-shell">
      <CalBookingEmbed calLink={site.calComLink} />
    </div>
  </section>

  <section class="border-t border-white/10 bg-white/5 section-pad">
    <div class="container-shell">
      <SectionHeading
        eyebrow="Before booking"
        title="Charter policies."
        copy="A quick check on deposits, cancellation, weather, payment, and mate tipping before you request a date."
      />
      <CharterPolicies compact />
    </div>
  </section>
</Layout>
