---
import CharterPolicies from "@components/CharterPolicies.astro";
import DirectionsBlock from "@components/DirectionsBlock.astro";
import FAQAccordion from "@components/FAQAccordion.astro";
import PageHeader from "@components/PageHeader.astro";
import SectionHeading from "@components/SectionHeading.astro";
import Layout from "@layouts/Layout.astro";
---

<Layout
  title="FAQ | Ocean City MD Fishing Charter Questions"
  description="Answers to common questions about booking, payment, weather, kids, licenses, departure location, and private Ocean City fishing charter policies."
  canonicalPath="/faq/"
>
  <PageHeader
    title="FAQ"
    mascot="thinking-fish-faq.png"
    mascotAlt="A curious fish thinking about charter questions"
    background="section-art/faq-section-title.webp"
    backgroundPosition="center bottom"
    showTitle={false}
  />

  <section class="section-pad">
    <div class="container-shell">
      <FAQAccordion />
    </div>
  </section>

  <section class="border-t border-white/10 py-16">
    <div class="container-shell">
      <SectionHeading
        eyebrow="Charter policies"
        title="The main trip policies in one place."
        copy="Deposits, cancellations, weather, payment, and mate tipping are the details guests usually need before booking."
      />
      <CharterPolicies compact />
    </div>
  </section>

  <section class="border-t border-white/10 bg-white/5 py-16">
    <div class="container-shell">
      <SectionHeading
        eyebrow="Marina & directions"
        title="Arrival details."
        copy="Use this as the starting point, then follow the exact parking and dock instructions Captain Kyle confirms before the trip."
      />
      <DirectionsBlock />
    </div>
  </section>

</Layout>
