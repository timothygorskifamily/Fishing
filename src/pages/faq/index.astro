---
import CTAButton from "@components/CTAButton.astro";
import FAQAccordion from "@components/FAQAccordion.astro";
import SectionHeading from "@components/SectionHeading.astro";
import Layout from "@layouts/Layout.astro";
import { site } from "@data/site";
import { smsHref } from "@lib/links";
---

<Layout
  title="FAQ | Ocean City MD Fishing Charter Questions"
  description="Answers to common questions about booking, payment, weather, kids, licenses, departure location, and private Ocean City fishing charter policies."
  canonicalPath="/faq/"
>
  <section class="border-b border-white/10 bg-harbor/50 section-pad">
    <div class="container-shell">
      <SectionHeading
        eyebrow="FAQ"
        title="Good questions before a day on the water."
        copy="A quick read on booking, weather, what to bring, and how final trip details are confirmed."
      />
      <div class="flex flex-col gap-3 sm:flex-row">
        <CTAButton href="/book/" label="Check Availability" icon="calendar" />
        <CTAButton href={smsHref(site.smsPhone)} label="Call/Text Captain" icon="phone" variant="ghost" />
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-shell grid gap-10 lg:grid-cols-[0.75fr_1.25fr]">
      <aside class="lg:sticky lg:top-28 lg:self-start">
        <div class="card p-5">
          <p class="eyebrow mb-3">Need something specific?</p>
          <h2 class="text-2xl font-black text-white">Ask the captain.</h2>
          <p class="mt-3 text-sm leading-7 text-mist">
            Weather, target species, trip timing, and group details are always confirmed directly before the day is locked in.
          </p>
        </div>
      </aside>
      <FAQAccordion />
    </div>
  </section>

  <section class="border-t border-white/10 bg-[#081720] py-16">
    <div class="container-shell grid gap-6 md:grid-cols-[1fr_auto] md:items-center">
      <div>
        <p class="eyebrow mb-3">Still deciding?</p>
        <h2 class="text-3xl font-black text-white md:text-4xl">Ask a question, then request your date.</h2>
      </div>
      <CTAButton href={smsHref(site.smsPhone)} label="Call/Text Captain" icon="phone" variant="ghost" />
    </div>
  </section>
</Layout>
