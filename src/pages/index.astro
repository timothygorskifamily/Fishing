---
import CTAButton from "@components/CTAButton.astro";
import FishSpeciesGrid from "@components/FishSpeciesGrid.astro";
import GalleryGrid from "@components/GalleryGrid.astro";
import Hero from "@components/Hero.astro";
import SectionHeading from "@components/SectionHeading.astro";
import TripCard from "@components/TripCard.astro";
import Layout from "@layouts/Layout.astro";
import { site } from "@data/site";
import { imagePath, smsHref } from "@lib/links";

const tripOptions = site.tripTypes;
const fishingMoments = [
  {
    src: "fish-tautog.jpg",
    alt: "Smiling angler holding a large tautog on an Ocean City fishing trip"
  },
  {
    src: "fish-red-drum.jpg",
    alt: "Angler smiling with a red drum beside the boat"
  },
  {
    src: "fish-sheepshead.jpg",
    alt: "Angler holding a sheepshead on calm Ocean City water"
  },
  {
    src: "fish-bowfishing.jpg",
    alt: "Two anglers bowfishing beside the Ocean City Guide Service boat"
  }
];
---

<Layout
  title="Ocean City MD Fishing Charter | Private SeaVee Charters"
  description="Book a private Ocean City, Maryland fishing charter aboard a 29' SeaVee. Review trips, see the boat, and request your date."
  canonicalPath="/"
>
  <Hero />

  <section class="border-b border-white/10 bg-[#061016] py-4 md:py-5">
    <div class="container-shell">
      <div class="grid grid-cols-2 gap-3 md:grid-cols-4">
        {
          fishingMoments.map((image) => (
            <figure class="image-sheen overflow-hidden rounded-lg border border-white/12 bg-panel shadow-lift">
              <img
                src={imagePath(image.src)}
                alt={image.alt}
                class="aspect-[4/3] w-full object-cover"
                loading="eager"
                decoding="async"
              />
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-shell">
      <SectionHeading
        eyebrow="Trip options"
        title="Fish the day that fits the season."
        copy="Pick the trip that fits your crew. The captain confirms timing, weather, and the best plan before you go."
      />
      <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-4">
        {tripOptions.map((trip) => <TripCard trip={trip} compact />)}
      </div>
    </div>
  </section>

  <section class="border-y border-white/10 bg-[#081720] section-pad">
    <div class="container-shell grid gap-10 lg:grid-cols-[0.92fr_1.08fr] lg:items-center">
      <div class="image-sheen overflow-hidden rounded-lg border border-white/12 bg-panel shadow-lift">
        <img
          src={imagePath("boat-running.jpg")}
          alt="29 foot SeaVee running on coastal water near Ocean City"
          class="aspect-[4/3] w-full object-cover"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div>
        <SectionHeading
          eyebrow="The boat"
          title="A clean 29' SeaVee ready for Ocean City water."
          copy="A private center-console setup with room to fish, move, and enjoy the day without clutter."
        />
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <CTAButton href="/boat/" label="See Boat & Photos" />
          <CTAButton href={smsHref(site.smsPhone)} label="Ask The Captain" icon="phone" variant="ghost" />
        </div>
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-shell">
      <SectionHeading
        eyebrow="What we catch"
        title="Flounder, tog, rockfish, drum, and more."
        copy="Common Ocean City targets with broad size ranges to help set expectations."
      />
      <FishSpeciesGrid limit={8} />
      <div class="mt-8">
        <CTAButton href="/trips/#fish-models" label="Open 3D Fish Lab" variant="secondary" />
      </div>
    </div>
  </section>

  <section class="border-y border-white/10 bg-harbor/54 section-pad">
    <div class="container-shell">
      <div class="grid gap-8 lg:grid-cols-[0.78fr_1.22fr] lg:items-start">
        <div>
          <SectionHeading
            eyebrow="Gallery"
            title="Boat days and catches."
          />
          <CTAButton href="/gallery/" label="View Gallery" variant="subtle" />
        </div>
        <GalleryGrid limit={4} minimal />
      </div>
    </div>
  </section>

  <section class="border-t border-white/10 py-10">
    <div class="container-shell flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-sm font-bold leading-6 text-mist md:text-base">
        Questions before booking? Review trip details, weather notes, and what to bring.
      </p>
      <CTAButton href="/faq/" label="Read FAQ" variant="subtle" />
    </div>
  </section>
</Layout>
