---
import CTAButton from "@components/CTAButton.astro";
import GalleryGrid from "@components/GalleryGrid.astro";
import Hero from "@components/Hero.astro";
import Layout from "@layouts/Layout.astro";
import { site } from "@data/site";
import { imagePath, withBase } from "@lib/links";

const fishingMoments = [
  {
    src: "captain-rockfish.jpg",
    alt: "Captain Kyle holding a large rockfish aboard the charter boat"
  },
  {
    src: "young-angler-flounder.jpg",
    alt: "Young angler smiling with a flounder aboard the charter boat"
  },
  {
    src: "charter-trolling-catch.jpg",
    alt: "Guests with an inshore trolling catch on the dock"
  },
  {
    src: "sunset-boat-rail.jpg",
    alt: "Sunset over the water from the charter boat rail"
  }
];

const tripsBySlug = new Map(site.tripTypes.map((trip) => [trip.slug, trip]));
const homeTripGroups = site.tripGroups.map((group) => ({
  ...group,
  trips: group.tripSlugs.map((slug) => tripsBySlug.get(slug)).filter(Boolean)
}));
---

<Layout
  title="Ocean City MD Fishing Charter | Private SeaVee Charters"
  description="Book a private Ocean City, Maryland fishing charter aboard a 29' SeaVee. Review trips, see the boat, and request your date."
  canonicalPath="/"
>
  <Hero />

  <section class="border-b border-sky-100 bg-white/70 py-4 md:py-5">
    <div class="container-shell">
      <div class="grid grid-cols-2 gap-3 md:grid-cols-4">
        {
          fishingMoments.map((image) => (
            <figure class="overflow-hidden rounded-lg border border-white/12 bg-white/90 shadow-lift">
              <img
                src={imagePath(image.src)}
                alt={image.alt}
                class:list={["aspect-[4/5] w-full object-cover", image.src === "young-angler-flounder.jpg" && "scale-80"]}
                loading="eager"
                decoding="async"
              />
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-shell">
      <div class="grid gap-7">
        {
          homeTripGroups.map((group) => (
            <section class="border-b border-sky-100 pb-7 last:border-b-0 last:pb-0" aria-label={`${group.title} trips`}>
              <div class="mb-3">
                <div>
                  <p class="text-xs font-black uppercase tracking-[0.16em] text-[#0788a5]">{group.title}</p>
                  <p class="mt-1 text-sm font-bold text-mist">{group.tripSlugs.length} options</p>
                </div>
              </div>

              <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
                {
                  group.trips.map((trip) => trip && (
                    <a
                      href={withBase(`/trips/#${trip.slug}`)}
                      class="group min-w-0 rounded-lg border border-white/12 bg-white/90 p-4 shadow-[0_14px_36px_rgba(16,80,103,0.10)] transition hover:-translate-y-1 hover:border-seafoam/40"
                    >
                      <div class="flex min-w-0 items-start justify-between gap-3">
                        <div class="min-w-0">
                          <p class="eyebrow mb-2">{trip.eyebrow}</p>
                          <h3 class="text-lg font-black leading-tight text-white">{trip.name}</h3>
                        </div>
                        <span class="shrink-0 rounded-md bg-sky-50 px-2 py-1 text-xs font-black text-ink ring-1 ring-sky-100">
                          {trip.price}
                        </span>
                      </div>
                      <p class="mt-3 text-sm font-bold leading-6 text-mist">{trip.duration} / {trip.times}</p>
                    </a>
                  ))
                }
              </div>
            </section>
          ))
        }
      </div>
      <div class="mt-8">
        <CTAButton href="/trips/" label="View Trips & Rates" />
      </div>
    </div>
  </section>

  <section class="border-y border-white/10 bg-white/5 section-pad">
    <div class="container-shell">
      <GalleryGrid minimal />
    </div>
  </section>
</Layout>
