---
import CTAButton from "@components/CTAButton.astro";
import FishSpeciesGrid from "@components/FishSpeciesGrid.astro";
import GalleryGrid from "@components/GalleryGrid.astro";
import Hero from "@components/Hero.astro";
import SectionHeading from "@components/SectionHeading.astro";
import TripCard from "@components/TripCard.astro";
import Layout from "@layouts/Layout.astro";
import { site } from "@data/site";
import { imagePath, smsHref } from "@lib/links";
import { Compass, ShipWheel, Waves } from "@lucide/astro";

const previewTrips = site.tripTypes.slice(0, 3);
const fishingMoments = [
  {
    src: "fish-tautog.jpg",
    alt: "Smiling angler holding a large tautog on an Ocean City fishing trip"
  },
  {
    src: "fish-red-drum.jpg",
    alt: "Angler smiling with a red drum beside the boat"
  },
  {
    src: "fish-sheepshead.jpg",
    alt: "Angler holding a sheepshead on calm Ocean City water"
  },
  {
    src: "fish-bowfishing.jpg",
    alt: "Two anglers bowfishing beside the Ocean City Guide Service boat"
  }
];
---

<Layout
  title="Ocean City MD Fishing Charter | Private SeaVee Charters"
  description="Book a private Ocean City, Maryland fishing charter aboard a 29' SeaVee tower boat. Review trips, see the boat, and request your date."
  canonicalPath="/"
>
  <Hero />

  <section class="border-b border-white/10 bg-[#061016] py-4 md:py-5">
    <div class="container-shell">
      <div class="grid grid-cols-2 gap-3 md:grid-cols-4">
        {
          fishingMoments.map((image) => (
            <figure class="image-sheen overflow-hidden rounded-lg border border-white/12 bg-panel shadow-lift">
              <img
                src={imagePath(image.src)}
                alt={image.alt}
                class="aspect-[4/3] w-full object-cover"
                loading="eager"
                decoding="async"
              />
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-shell">
      <SectionHeading
        eyebrow="Trip options"
        title="Fish the day that fits the season."
        copy="Choose a starting point, then confirm the final plan with the captain. Availability, departure times, and target species vary with weather and conditions."
      />
      <div class="grid gap-5 lg:grid-cols-3">
        {previewTrips.map((trip) => <TripCard trip={trip} compact />)}
      </div>
      <div class="mt-8">
        <CTAButton href="/trips/" label="View All Trips & Rates" variant="subtle" />
      </div>
    </div>
  </section>

  <section class="border-y border-white/10 bg-[#081720] section-pad">
    <div class="container-shell grid gap-10 lg:grid-cols-[0.92fr_1.08fr] lg:items-center">
      <div class="image-sheen overflow-hidden rounded-lg border border-white/12 bg-panel shadow-lift">
        <img
          src={imagePath("boat-running.jpg")}
          alt="29 foot SeaVee tower boat running on coastal water near Ocean City"
          class="aspect-[4/3] w-full object-cover"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div>
        <SectionHeading
          eyebrow="The boat"
          title="A 29' SeaVee tower boat with a serious fishing attitude."
          copy="The platform matters. This 2006 SeaVee keeps the focus on fishability, clean movement around the center-console layout, and the sightline advantage of a tower when the water calls for it."
        />
        <div class="grid gap-4 sm:grid-cols-3">
          <div class="card p-5">
            <ShipWheel class="mb-4 size-7 text-seafoam" aria-hidden="true" />
            <h3 class="font-black text-white">Center-console layout</h3>
            <p class="mt-2 text-sm leading-6 text-mist">Open, practical, and made for fishing days.</p>
          </div>
          <div class="card p-5">
            <Compass class="mb-4 size-7 text-seafoam" aria-hidden="true" />
            <h3 class="font-black text-white">Tower visibility</h3>
            <p class="mt-2 text-sm leading-6 text-mist">A higher view when spotting water, birds, or movement matters.</p>
          </div>
          <div class="card p-5">
            <Waves class="mb-4 size-7 text-seafoam" aria-hidden="true" />
            <h3 class="font-black text-white">Ocean City ready</h3>
            <p class="mt-2 text-sm leading-6 text-mist">Configured around private days from Maryland's coast.</p>
          </div>
        </div>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <CTAButton href="/boat/" label="See The Boat" />
          <CTAButton href="/gallery/" label="View Boat Photos" variant="secondary" />
          <CTAButton href={smsHref(site.smsPhone)} label="Ask The Captain" icon="phone" variant="ghost" />
        </div>
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-shell">
      <SectionHeading
        eyebrow="What we catch"
        title="Flounder, tog, rockfish, drum, and more."
        copy="A quick look at common Ocean City Guide Service targets. Sizes are broad guide estimates, not guarantees or regulations, and should be confirmed with the captain."
      />
      <FishSpeciesGrid limit={8} />
      <div class="mt-8">
        <CTAButton href="/trips/#fish-models" label="Open 3D Fish Lab" variant="secondary" />
      </div>
    </div>
  </section>

  <section class="border-y border-white/10 bg-harbor/54 section-pad">
    <div class="container-shell">
      <div class="grid gap-8 lg:grid-cols-[0.78fr_1.22fr] lg:items-start">
        <div>
          <SectionHeading
            eyebrow="Gallery"
            title="Boat days, catches, and Ocean City water."
            copy="A clean look at the boat, the water, and the kind of fishing days this charter is built around."
          />
          <CTAButton href="/gallery/" label="View Gallery" variant="subtle" />
        </div>
        <GalleryGrid limit={4} />
      </div>
    </div>
  </section>

  <section class="border-t border-white/10 py-10">
    <div class="container-shell flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-sm font-bold leading-6 text-mist md:text-base">
        Questions before booking? Review trip details, weather notes, and what to bring.
      </p>
      <CTAButton href="/faq/" label="Read FAQ" variant="subtle" />
    </div>
  </section>
</Layout>
