---
import CTAButton from "@components/CTAButton.astro";
import GalleryGrid from "@components/GalleryGrid.astro";
import Hero from "@components/Hero.astro";
import SectionHeading from "@components/SectionHeading.astro";
import Layout from "@layouts/Layout.astro";
import { site } from "@data/site";
import { imagePath } from "@lib/links";

const fishingMoments = [
  {
    src: "captain-rockfish.jpg",
    alt: "Captain Kyle holding a large rockfish aboard the charter boat"
  },
  {
    src: "young-angler-flounder.jpg",
    alt: "Young angler smiling with a flounder aboard the charter boat"
  },
  {
    src: "charter-trolling-catch.jpg",
    alt: "Guests with an inshore trolling catch on the dock"
  },
  {
    src: "sunset-boat-rail.jpg",
    alt: "Sunset over the water from the charter boat rail"
  }
];
---

<Layout
  title="Ocean City MD Fishing Charter | Private SeaVee Charters"
  description="Book a private Ocean City, Maryland fishing charter aboard a 29' SeaVee. Review trips, see the boat, and request your date."
  canonicalPath="/"
>
  <Hero />

  <section class="border-b border-sky-100 bg-white/70 py-4 md:py-5">
    <div class="container-shell">
      <div class="grid grid-cols-2 gap-3 md:grid-cols-4">
        {
          fishingMoments.map((image) => (
            <figure class="image-sheen overflow-hidden rounded-lg border border-white/12 bg-panel shadow-lift">
              <img
                src={imagePath(image.src)}
                alt={image.alt}
                class="aspect-[4/3] w-full object-cover"
                loading="eager"
                decoding="async"
              />
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-shell">
      <SectionHeading
        eyebrow="Trips"
        title="Trips, rates, and timing in one place."
        copy="Bay, wreck, trolling, shark, and sunset options are organized on the trips page."
      />
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        {
          site.tripGroups.map((group) => (
            <a href="/trips/" class="rounded-lg border border-white/12 bg-panel/78 p-5 transition hover:-translate-y-1 hover:border-seafoam/35 hover:bg-panel">
              <p class="eyebrow mb-2">{group.title}</p>
              <h3 class="text-xl font-black text-white">{group.title} trips</h3>
              <p class="mt-2 text-sm font-bold text-mist">{group.tripSlugs.length} options</p>
            </a>
          ))
        }
      </div>
      <div class="mt-8">
        <CTAButton href="/trips/" label="View Trips & Rates" />
      </div>
    </div>
  </section>

  <section class="border-y border-white/10 bg-white/5 section-pad">
    <div class="container-shell">
      <SectionHeading
        eyebrow="Gallery"
        title="Boat days and catches."
      />
      <GalleryGrid minimal />
    </div>
  </section>

</Layout>
