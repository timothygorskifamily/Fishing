---
import CommonCatchesSection from "@components/CommonCatchesSection.astro";
import PageHeader from "@components/PageHeader.astro";
import TripChooser from "@components/TripChooser.astro";
import Layout from "@layouts/Layout.astro";
import { site } from "@data/site";
---

<Layout
  title="Trips & Rates | Ocean City MD Private Fishing Charter"
  description="Review Ocean City Guide Service bay fishing, wreck fishing, Off Shore, inshore trolling, night shark fishing, and sunset cruise rates and trip times."
  canonicalPath="/trips/"
>
  <PageHeader
    title="Trips"
    mascot="trips-mascot.png"
    mascotAlt="A fish mascot planning fishing trips with a chart"
    background="section-art/trips-section-title.webp"
    backgroundPosition="center top"
    showTitle={false}
  />

  <section class="section-pad">
    <div class="container-shell">
      <TripChooser />

      <div class="mt-10 rounded-lg border border-gold/25 bg-gold/10 p-5 text-sm leading-7 text-fog">
        <p>
          <strong class="text-white">Trip note:</strong> Fishing locations, route, and target species may vary by season,
          weather, tide, and current regulations. Captain Kyle confirms the final plan before your trip.
        </p>
      </div>
    </div>
  </section>

  <CommonCatchesSection />
</Layout>
